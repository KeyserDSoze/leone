# Firebase — variabili pubbliche (Client SDK)
# Queste variabili vanno nei GitHub Secrets e vengono iniettate durante il build.
# NON sono segreti nel senso tradizionale: la sicurezza è nelle Firebase Security Rules.

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_DATABASE_URL=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_APP_ID=
