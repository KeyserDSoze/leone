---
// src/pages/quiz.astro — Pagina giocatori
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>CervelLeone 🦁</title>
  <link rel="icon" href="/favicon.ico" />
  <link rel="stylesheet" href="/global.css" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green-deep:  #3A5A35;
      --green:       #4B6F44;
      --green-mid:   #5C8454;
      --green-soft:  #EDF3E8;
      --green-line:  #CBDCC2;
      --gold:        #B8923D;
      --gold-soft:   #F5EEDC;
      --gold-line:   #E4D3A6;
      --ink:         #33402F;
      --muted:       #7C8A76;
      --card:        rgba(255,255,255,0.97);
      --track:       #E9EFE4;
      --danger:      #B5564B;
      --danger-soft: #F5E6E3;
    }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
      color: var(--ink);
      padding: 16px;
    }

    .screen {
      display: none;
      width: 100%;
      max-width: 440px;
      flex-direction: column;
      align-items: center;
      gap: 0;
    }
    .screen.active { display: flex; }

    .card {
      background: var(--card);
      border-radius: 26px;
      padding: 34px 26px;
      box-shadow: 0 18px 50px rgba(58, 90, 53, 0.16);
      border: 1px solid rgba(203, 220, 194, 0.7);
      width: 100%;
      text-align: center;
    }

    .lion-emoji { font-size: 58px; display: block; margin-bottom: 10px; }
    .big-icon   { font-size: 70px; display: block; margin-bottom: 12px; }

    .quiz-title {
      font-family: 'Playfull Rocket', system-ui, cursive;
      font-size: 28px;
      color: var(--green);
      margin-bottom: 6px;
      line-height: 1.2;
    }
    .quiz-subtitle {
      font-size: 15px;
      color: var(--muted);
      margin-bottom: 22px;
    }

    /* ── JOIN ── */
    .input-username {
      width: 100%;
      padding: 14px 16px;
      border: 2px solid var(--green-line);
      border-radius: 14px;
      font-size: 18px;
      text-align: center;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      margin-bottom: 10px;
      background: #F7FAF4;
      color: var(--ink);
    }
    .input-username:focus { border-color: var(--green-mid); box-shadow: 0 0 0 3px rgba(92,132,84,0.18); }

    .btn-primary {
      width: 100%;
      padding: 15px;
      background: linear-gradient(135deg, #5C8454, #3F6539);
      color: #fff;
      border: none;
      border-radius: 14px;
      font-size: 18px;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.1s, box-shadow 0.2s, opacity 0.2s;
      letter-spacing: 0.3px;
      box-shadow: 0 8px 20px rgba(63, 101, 57, 0.28);
    }
    .btn-primary:hover  { box-shadow: 0 10px 26px rgba(63, 101, 57, 0.36); }
    .btn-primary:active { transform: scale(0.97); }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; box-shadow: none; }

    .error-msg {
      color: var(--danger);
      font-size: 13px;
      min-height: 18px;
      margin-bottom: 8px;
    }

    /* ── LOBBY ── */
    .username-badge {
      display: inline-block;
      background: var(--green-soft);
      border: 2px solid var(--green-line);
      border-radius: 12px;
      padding: 8px 22px;
      font-size: 22px;
      font-weight: 700;
      color: var(--green-deep);
      margin: 10px 0 16px;
    }
    .lobby-waiting {
      font-size: 15px;
      color: var(--muted);
      animation: pulse-opacity 2s infinite;
    }
    @keyframes pulse-opacity {
      0%,100% { opacity: 1; }
      50%      { opacity: 0.4; }
    }

    /* ── QUESTION ── */
    .progress-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .progress-label {
      font-size: 13px;
      color: var(--muted);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.8px;
    }
    .category-badge {
      font-size: 11px;
      padding: 3px 8px;
      border-radius: 999px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .cat-leone   { background:var(--gold-soft); color:#8A6A2B; }
    .cat-general { background:var(--green-soft); color:var(--green-deep); }
    .cat-demo    { background:#EAF1F2; color:#3E6470; }
    .preview-icon {
      display: block;
      margin: 24px 0 22px;
      font-size: 70px;
      line-height: 1;
      filter: drop-shadow(0 8px 14px rgba(58, 90, 53, 0.12));
    }

    .timer-wrap {
      display: flex;
      justify-content: center;
      margin: 6px 0 14px;
    }
    .timer-circle {
      width: 58px;
      height: 58px;
      border-radius: 50%;
      background: var(--green-soft);
      border: 3px solid var(--green-mid);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      font-weight: 700;
      color: var(--green-deep);
      transition: background 0.3s, border-color 0.3s;
    }
    .timer-circle.urgent {
      background: var(--danger-soft);
      border-color: var(--danger);
      color: var(--danger);
      animation: timer-pulse 0.6s infinite;
    }
    @keyframes timer-pulse {
      0%,100% { transform: scale(1); }
      50%      { transform: scale(1.08); }
    }

    .question-text {
      font-size: 19px;
      font-weight: 600;
      color: var(--ink);
      line-height: 1.45;
      margin-bottom: 18px;
    }

    .answers-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    .btn-answer {
      padding: 14px 10px;
      border-radius: 14px;
      border: 2px solid transparent;
      cursor: pointer;
      text-align: left;
      font-size: 14px;
      line-height: 1.35;
      transition: transform 0.1s, box-shadow 0.15s, border-color 0.1s;
      display: flex;
      align-items: flex-start;
      gap: 6px;
    }
    .btn-answer:hover  { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(58,90,53,0.14); }
    .btn-answer:active { transform: scale(0.97); }

    /* Disabled non-selected: fade out */
    .btn-answer:disabled { cursor: not-allowed; transform: none; box-shadow: none; }
    .btn-answer:disabled:not(.selected) { opacity: 0.35; }

    .btn-answer-A { background:#EAF1F2; border-color:#C3D7DD; color:#2E5A66; }
    .btn-answer-B { background:#ECF4E6; border-color:#C5DCB8; color:#3A5A35; }
    .btn-answer-C { background:#F7EFE1; border-color:#E5D2B2; color:#8A5A2B; }
    .btn-answer-D { background:#F1ECF3; border-color:#D8C8DF; color:#6A4A78; }

    /* Selected answer: bright ring + full opacity */
    .btn-answer.selected { opacity: 1; font-weight: 700; }
    .btn-answer-A.selected { border-color: #4A8294; box-shadow: 0 0 0 3px rgba(74,130,148,0.30); }
    .btn-answer-B.selected { border-color: #5C8454; box-shadow: 0 0 0 3px rgba(92,132,84,0.32); }
    .btn-answer-C.selected { border-color: #C28A4D; box-shadow: 0 0 0 3px rgba(194,138,77,0.32); }
    .btn-answer-D.selected { border-color: #8A6BA0; box-shadow: 0 0 0 3px rgba(138,107,160,0.30); }

    .answer-label {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 22px;
      height: 22px;
      min-width: 22px;
      border-radius: 6px;
      font-weight: 700;
      font-size: 12px;
    }
    .btn-answer-A .answer-label { background:#C3D7DD; color:#2E5A66; }
    .btn-answer-B .answer-label { background:#C5DCB8; color:#3A5A35; }
    .btn-answer-C .answer-label { background:#E5D2B2; color:#8A5A2B; }
    .btn-answer-D .answer-label { background:#D8C8DF; color:#6A4A78; }

    /* ── RESULT ── */
    .result-summary {
      border-radius: 16px;
      padding: 14px 18px;
      margin-bottom: 14px;
    }
    .result-summary.correct { background:var(--green-soft); border: 2px solid var(--green-line); }
    .result-summary.wrong   { background:var(--danger-soft); border: 2px solid #E3C5C0; }
    .result-summary.skip    { background:#F6F7F4; border: 2px solid #E4E8E0; }
    .result-icon    { font-size: 36px; display: block; }
    .result-outcome { font-size: 16px; font-weight: 700; margin-top: 4px; }
    .result-pts     { font-size: 30px; font-weight: 800; margin-top: 2px; }
    .result-pts.positive { color: var(--green); }
    .result-pts.negative { color: var(--danger); }

    /* Answer distribution */
    .stats-section {
      margin: 18px 0 8px;
      text-align: left;
    }
    .stats-title {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.8px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 10px;
    }
    .stats-list {
      display: grid;
      gap: 9px;
    }
    .ans-row {
      position: relative;
      padding: 11px 13px;
      border-radius: 16px;
      border: 1px solid #E4E8E0;
      background: #FFFFFF;
      box-shadow: 0 6px 16px rgba(58, 90, 53, 0.05);
      transition: transform 0.15s;
    }
    .ans-row.is-correct {
      border-color: var(--green-mid);
      background: var(--green-soft);
    }
    .ans-row.is-mine:not(.is-correct) {
      border-color: #D9A39B;
      background: #FBF1EF;
    }
    .ans-head {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .ans-badge {
      width: 34px;
      height: 34px;
      min-width: 34px;
      border-radius: 10px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 16px;
    }
    .ans-badge.b-A { background:#C3D7DD; color:#2E5A66; }
    .ans-badge.b-B { background:#C5DCB8; color:#3A5A35; }
    .ans-badge.b-C { background:#E5D2B2; color:#8A5A2B; }
    .ans-badge.b-D { background:#D8C8DF; color:#6A4A78; }
    .ans-name {
      flex: 1;
      min-width: 0;
      font-size: 14px;
      font-weight: 700;
      color: var(--ink);
    }
    .ans-votes {
      font-size: 12px;
      color: var(--muted);
      white-space: nowrap;
    }
    .ans-pct {
      font-size: 19px;
      font-weight: 800;
      color: var(--green-deep);
      min-width: 46px;
      text-align: right;
    }
    .ans-row.is-mine:not(.is-correct) .ans-pct { color: #A24438; }
    .ans-bar {
      margin-top: 9px;
      background: var(--track);
      border-radius: 999px;
      height: 8px;
      overflow: hidden;
    }
    .ans-fill {
      height: 100%;
      border-radius: 999px;
      background: #CDD6C6;
      transition: width 0.7s ease;
    }
    .ans-fill.f-correct { background: linear-gradient(135deg, #6FA063, #4B6F44); }
    .ans-fill.f-mine    { background: linear-gradient(135deg, #C97A6E, #B5564B); }

    /* Correct-answer reveal panel */
    .correct-panel {
      margin-top: 16px;
      border-radius: 18px;
      border: 1.5px solid var(--green-mid);
      background: linear-gradient(180deg, #F3F8EF, #EAF2E4);
      padding: 16px 16px 14px;
      text-align: left;
      box-shadow: 0 10px 26px rgba(58, 90, 53, 0.10);
    }
    .cp-head {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.6px;
      text-transform: uppercase;
      color: var(--green-deep);
      margin-bottom: 10px;
    }
    .cp-answers { display: grid; gap: 7px; }
    .cp-answer {
      display: flex;
      align-items: center;
      gap: 10px;
      background: rgba(255,255,255,0.75);
      border: 1px solid var(--green-line);
      border-radius: 12px;
      padding: 8px 10px;
    }
    .cp-letter {
      width: 28px;
      height: 28px;
      min-width: 28px;
      border-radius: 8px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 13px;
    }
    .cp-letter.b-A { background:#C3D7DD; color:#2E5A66; }
    .cp-letter.b-B { background:#C5DCB8; color:#3A5A35; }
    .cp-letter.b-C { background:#E5D2B2; color:#8A5A2B; }
    .cp-letter.b-D { background:#D8C8DF; color:#6A4A78; }
    .cp-text { font-size: 14px; font-weight: 600; color: var(--ink); line-height: 1.35; }
    .cp-all {
      font-size: 14px;
      font-weight: 700;
      color: var(--green-deep);
      background: rgba(255,255,255,0.75);
      border: 1px solid var(--green-line);
      border-radius: 12px;
      padding: 10px 12px;
    }
    .cp-expl {
      margin-top: 11px;
      padding-top: 11px;
      border-top: 1px dashed var(--green-line);
      font-size: 13px;
      color: #4A5544;
      line-height: 1.5;
    }
    .explanation { font-size: 13px; color: var(--muted); font-style: italic; margin-top: 8px; }

    /* ── LEADERBOARD ── */
    .lb-list { list-style: none; width: 100%; margin-top: 14px; display: grid; gap: 10px; }
    .lb-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      border-radius: 18px;
      background: linear-gradient(180deg, #FFFFFF, #FAFCF7);
      border: 1px solid var(--green-line);
      box-shadow: 0 10px 24px rgba(58, 90, 53, 0.06);
    }
    .lb-item.me     { background:var(--green-soft); border-color:var(--green-mid); font-weight:700; }
    .lb-item.rank1  { background:#FBF4DE; border-color:var(--gold); }
    .lb-item.rank2  { background:#F4F6F1; border-color:#AEBBA6; }
    .lb-item.rank3  { background:#F6EEE2; border-color:#D8B98A; }
    .lb-item.lb-hidden { background:#F6F7F4; border-color:#E4E8E0; }
    .lb-rank  {
      width: 42px;
      min-width: 42px;
      height: 42px;
      border-radius: 14px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size:18px;
      font-weight:700;
      color:var(--green-deep);
      background: rgba(255,255,255,0.85);
    }
    .lb-copy { flex:1; min-width:0; text-align:left; }
    .lb-name  { display:block; font-size:15px; color:var(--ink); }
    .lb-sub { display:block; font-size:12px; color:var(--muted); margin-top:4px; }
    .lb-tags { display:flex; flex-wrap:wrap; gap:6px; margin-top:6px; }
    .lb-pill {
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:4px 8px;
      border-radius:999px;
      font-size:11px;
      font-weight:700;
      background:#EDF0EA;
      color:#5A6654;
    }
    .lb-pill.answer-A { background:#D9E7EC; color:#2E5A66; }
    .lb-pill.answer-B { background:#DDEBD3; color:#3A5A35; }
    .lb-pill.answer-C { background:#F0E2CA; color:#8A5A2B; }
    .lb-pill.answer-D { background:#E7DCEC; color:#6A4A78; }
    .lb-pill.correct { background:#DDEBD3; color:var(--green-deep); }
    .lb-pill.wrong { background:#F1DED9; color:#8A3E34; }
    .lb-pill.skip { background:#E4E8E0; color:#5A6654; }
    .lb-score {
      font-size:14px;
      font-weight:800;
      color:var(--green);
      background:#F1F6EC;
      border:1px solid var(--green-line);
      border-radius:999px;
      padding:8px 10px;
      white-space:nowrap;
    }

    /* ── FINISHED ── */
    .final-rank  {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 132px;
      padding: 12px 22px;
      border-radius: 999px;
      background: var(--gold-soft);
      border: 2px solid var(--gold-line);
      font-size:52px;
      font-weight:700;
      color:#8A6A2B;
      margin:8px 0;
    }
    .final-score { font-size:22px; color:var(--ink); font-weight:700; }
    .final-msg   { font-size:13px; color:var(--muted); margin-top:12px; line-height:1.5; }

    /* ── ERROR ── */
    #screen-error { max-width: 440px; padding: 16px; }
  </style>
</head>
<body>

<!-- LOADING -->
<div id="screen-loading" class="screen active">
  <div class="card">
    <span class="lion-emoji">🦁</span>
    <h1 class="quiz-title">CervelLeone</h1>
    <p class="lobby-waiting">Connessione in corso...</p>
  </div>
</div>

<!-- JOIN -->
<div id="screen-join" class="screen">
  <div class="card">
    <span class="lion-emoji">🦁</span>
    <h1 class="quiz-title">Benvenuto al CervelLeone</h1>
    <p class="quiz-subtitle">Scegli il tuo nome di battaglia</p>
    <input
      id="input-username"
      class="input-username"
      type="text"
      placeholder="Es: Zia Turbo, Zio Speed…"
      maxlength="24"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="words"
      spellcheck="false"
    />
    <p id="join-error" class="error-msg"></p>
    <button id="btn-join" class="btn-primary">Entra nel gioco 🎮</button>
  </div>
</div>

<!-- LOBBY -->
<div id="screen-lobby" class="screen">
  <div class="card">
    <span class="lion-emoji">🦁</span>
    <h1 class="quiz-title">Sei dentro!</h1>
    <p class="quiz-subtitle">Aspetta che inizi il gioco.</p>
    <div class="username-badge" id="lobby-username">...</div>
    <p class="lobby-waiting" style="margin-top:14px">⏳ In attesa dell'host…</p>
  </div>
</div>

<!-- PREVIEW — mostrata quando questionVisible=false -->
<div id="screen-preview" class="screen">
  <div class="card">
    <div class="progress-row">
      <span id="preview-progress" class="progress-label">Domanda</span>
      <span id="preview-category" class="category-badge cat-general">Cultura</span>
    </div>
    <span id="preview-icon" class="preview-icon">🌍</span>
    <p style="font-size:17px;font-weight:600;color:#33402F;margin-bottom:8px">
      Il babbo sta per rivelare la domanda...
    </p>
    <p class="lobby-waiting">⏳ Tieniti pronto!</p>
  </div>
</div>

<!-- QUESTION (also used for "answered" state — buttons disabled + selected highlighted) -->
<div id="screen-question" class="screen">
  <div class="card">
    <div class="progress-row">
      <span id="question-progress" class="progress-label">Demo</span>
      <span id="question-category" class="category-badge cat-general">Cultura</span>
    </div>
    <div class="timer-wrap">
      <div class="timer-circle" id="question-timer">20</div>
    </div>
    <p id="question-text" class="question-text">...</p>
    <div class="answers-grid">
      <button class="btn-answer btn-answer-A" id="btn-A" data-answer="A">
        <span class="answer-label">A</span>
        <span id="answer-text-A">...</span>
      </button>
      <button class="btn-answer btn-answer-B" id="btn-B" data-answer="B">
        <span class="answer-label">B</span>
        <span id="answer-text-B">...</span>
      </button>
      <button class="btn-answer btn-answer-C" id="btn-C" data-answer="C">
        <span class="answer-label">C</span>
        <span id="answer-text-C">...</span>
      </button>
      <button class="btn-answer btn-answer-D" id="btn-D" data-answer="D">
        <span class="answer-label">D</span>
        <span id="answer-text-D">...</span>
      </button>
    </div>
  </div>
</div>

<!-- RESULT -->
<div id="screen-result" class="screen">
  <div class="card">
    <div id="result-content"><!-- filled by JS --></div>
  </div>
</div>

<!-- QUESTION LEADERBOARD -->
<div id="screen-question-leaderboard" class="screen">
  <div class="card">
    <span style="font-size:48px">⚡</span>
    <h2 class="quiz-title" style="margin-top:6px">Classifica della domanda</h2>
    <p class="quiz-subtitle">Chi ha risposto meglio e più in fretta</p>
    <ul class="lb-list" id="question-leaderboard-list"><!-- filled by JS --></ul>
    <p class="lobby-waiting" style="margin-top:14px">⏳ L'host sta per continuare…</p>
  </div>
</div>

<!-- LEADERBOARD -->
<div id="screen-leaderboard" class="screen">
  <div class="card">
    <span style="font-size:48px">🏆</span>
    <h2 class="quiz-title" style="margin-top:6px">Classifica</h2>
    <ul class="lb-list" id="leaderboard-list"><!-- filled by JS --></ul>
    <p class="lobby-waiting" id="lb-waiting-msg" style="margin-top:14px">🎭 L'host sta rivelando la classifica…</p>
  </div>
</div>

<!-- FINISHED -->
<div id="screen-finished" class="screen">
  <div class="card">
    <span class="lion-emoji">🦁</span>
    <h1 class="quiz-title">CervelLeone finito!</h1>
    <p class="quiz-subtitle">Grazie per aver giocato</p>
    <div class="final-rank" id="final-rank">—</div>
    <p class="final-score" id="final-score">0 punti</p>
    <p class="final-msg">Leone vi ringrazierà quando sarà grande 🦁</p>
  </div>
</div>

<!-- ERROR -->
<div id="screen-error" class="screen" style="width:100%">
  <div class="card">
    <span class="big-icon">😕</span>
    <h2 class="quiz-title">Ops!</h2>
    <p id="error-message" class="quiz-subtitle">Si è verificato un errore.</p>
    <button onclick="location.reload()" class="btn-primary" style="margin-top:12px">
      Riprova 🔄
    </button>
  </div>
</div>

<script>
import { db, ensureAnonymousUser } from "../lib/firebase";
import { joinGame, checkUsernameTaken, submitAnswer } from "../lib/quiz/playerApi";
import { setupPresence } from "../lib/quiz/presence";
import { GAME_ID } from "../lib/quiz/config";
import { getCorrectAnswerIds } from "../lib/quiz/publicResult";
import { calculatePoints } from "../lib/quiz/scoring";
import { ref, onValue, get } from "firebase/database";
import type {
  GameState,
  PublicQuestion,
  PublicResult,
  PublicAnswerStats,
  PublicQuestionLeaderboardEntry,
  LeaderboardEntry,
  AnswerId,
} from "../lib/quiz/types";

// ── Labels sottocategorie ──────────────────────────────────────────────────
const SUB_LABELS: Record<string, string> = {
  "geografia":           "Geografia 🌍",
  "storia-antica":       "Storia Antica 🏛️",
  "storia-moderna":      "Storia Moderna 📜",
  "tecnologia":          "Tecnologia 💻",
  "politica-italia":     "Politica 🇮🇹",
  "grammatica-italiana": "Italiano 📝",
  "matematica":          "Matematica 🔢",
  "fisica-chimica":      "Fisica & Chimica 🧪",
  "arte":                "Arte & Letteratura 🎨",
  "musica":              "Musica 🎵",
  "religione":           "Religione 🕊️",
  "leone":               "Leone 🦁",
  "demo":                "Demo",
};

const SUB_NAMES: Record<string, string> = {
  "geografia":           "Geografia",
  "storia-antica":       "Storia Antica",
  "storia-moderna":      "Storia Moderna",
  "tecnologia":          "Tecnologia",
  "politica-italia":     "Politica",
  "grammatica-italiana": "Italiano",
  "matematica":          "Matematica",
  "fisica-chimica":      "Fisica & Chimica",
  "arte":                "Arte & Letteratura",
  "musica":              "Musica",
  "religione":           "Religione",
  "leone":               "Leone",
  "demo":                "Demo",
};

const SUB_ICONS: Record<string, string> = {
  "geografia":           "🌍",
  "storia-antica":       "🏛️",
  "storia-moderna":      "📜",
  "tecnologia":          "💻",
  "politica-italia":     "🇮🇹",
  "grammatica-italiana": "📝",
  "matematica":          "🔢",
  "fisica-chimica":      "🧪",
  "arte":                "🎨",
  "musica":              "🎵",
  "religione":           "🕊️",
  "leone":               "🦁",
  "demo":                "🎓",
};

function humanizeSub(sub?: string): string {
  return sub ? (SUB_LABELS[sub] ?? "Cultura") : "Cultura";
}

function subjectName(sub?: string): string {
  return sub ? (SUB_NAMES[sub] ?? "Cultura") : "Cultura";
}

function subjectIcon(sub?: string): string {
  return sub ? (SUB_ICONS[sub] ?? "🌿") : "🌿";
}

function formatResponseTime(responseMs: number | null): string {
  if (responseMs == null) return "Tempo scaduto";
  const seconds = responseMs / 1000;
  return `${seconds < 10 ? seconds.toFixed(1) : Math.round(seconds)}s`;
}

// ── State ──────────────────────────────────────────────────────────────────
let currentUid: string | null = null;
let currentUsername: string | null = null;
let hasAnswered = false;
let myAnswerId: string | null = null;
let myAnsweredAt: number | null = null;
let currentQuestionId: string | null = null;
let lastQuestionId: string | null = null;
let currentGameSession: string | null = null;
let lastGameSession: string | null = null;
let timerInterval: ReturnType<typeof setInterval> | null = null;
let gameUnsubscribe: (() => void) | null = null;

// ── Session persistence ────────────────────────────────────────────────────
const SESSION_KEY = "leone_quiz_session";

function saveSession(uid: string, username: string) {
  localStorage.setItem(SESSION_KEY, JSON.stringify({ uid, username }));
}

function loadSession(): { uid: string; username: string } | null {
  try {
    const raw = localStorage.getItem(SESSION_KEY);
    return raw ? JSON.parse(raw) : null;
  } catch {
    return null;
  }
}

function clearSession() {
  localStorage.removeItem(SESSION_KEY);
}

// ── Screen management ──────────────────────────────────────────────────────
function showScreen(id: string) {
  document.querySelectorAll(".screen").forEach((el) => {
    el.classList.remove("active");
  });
  const el = document.getElementById(`screen-${id}`);
  if (el) el.classList.add("active");
}

function showError(msg: string) {
  const el = document.getElementById("error-message");
  if (el) el.textContent = msg;
  showScreen("error");
}

// ── Timer ──────────────────────────────────────────────────────────────────
function startTimer(endsAt: number) {
  stopTimer();
  const timerEl = document.getElementById("question-timer");
  if (!timerEl) return;

  function tick() {
    const remaining = Math.max(0, Math.ceil((endsAt - Date.now()) / 1000));
    timerEl!.textContent = String(remaining);
    timerEl!.classList.toggle("urgent", remaining <= 5);
  }

  tick();
  timerInterval = setInterval(tick, 500);
}

function stopTimer() {
  if (timerInterval) {
    clearInterval(timerInterval);
    timerInterval = null;
  }
}

// ── Render preview (questionVisible=false) ─────────────────────────────────
function showPreview(pq: PublicQuestion) {
  stopTimer();
  const progressEl = document.getElementById("preview-progress");
  const categoryEl = document.getElementById("preview-category");
  const iconEl = document.getElementById("preview-icon");

  if (progressEl) {
    progressEl.textContent =
      pq.category === "demo" ? "Domanda demo" : `Domanda ${pq.index} / ${pq.total}`;
  }

  if (categoryEl) {
    if (pq.category === "leone") {
      categoryEl.textContent = "Leone";
      categoryEl.className = "category-badge cat-leone";
      if (iconEl) iconEl.textContent = "🦁";
    } else if (pq.category === "demo") {
      categoryEl.textContent = "Demo";
      categoryEl.className = "category-badge cat-demo";
      if (iconEl) iconEl.textContent = "🎓";
    } else {
      categoryEl.textContent = subjectName(pq.subcategory);
      categoryEl.className = "category-badge cat-general";
      if (iconEl) iconEl.textContent = subjectIcon(pq.subcategory);
    }
  }

  showScreen("preview");
}

// ── Render question ────────────────────────────────────────────────────────
function renderQuestion(
  q: PublicQuestion,
  endsAt: number,
  opts: { disabled?: boolean; selectedId?: string | null } = {}
) {
  const isDemo = q.category === "demo";
  const progressEl = document.getElementById("question-progress");
  const categoryEl = document.getElementById("question-category");
  const textEl = document.getElementById("question-text");

  if (progressEl) {
    progressEl.textContent = isDemo
      ? "Domanda demo"
      : `Domanda ${q.index} / ${q.total}`;
  }

  if (categoryEl) {
    if (isDemo) {
      categoryEl.textContent = "Demo";
      categoryEl.className = "category-badge cat-demo";
    } else if (q.category === "leone") {
      categoryEl.textContent = "Leone 🦁";
      categoryEl.className = "category-badge cat-leone";
    } else {
      categoryEl.textContent = humanizeSub(q.subcategory);
      categoryEl.className = "category-badge cat-general";
    }
  }

  if (textEl) textEl.textContent = q.text;

  const ids: ("A" | "B" | "C" | "D")[] = ["A", "B", "C", "D"];
  ids.forEach((id) => {
    const answerEl = document.getElementById(`answer-text-${id}`);
    const btn = document.getElementById(`btn-${id}`) as HTMLButtonElement | null;
    const answer = q.answers.find((a) => a.id === id);
    if (answerEl) answerEl.textContent = answer?.text ?? "";
    if (btn) {
      btn.disabled = opts.disabled ?? false;
      btn.classList.toggle("selected", opts.selectedId === id);
    }
  });

  startTimer(endsAt);
  showScreen("question");
}

// ── Render result with distribution bars ───────────────────────────────────
function renderResult(
  result: PublicResult,
  stats: PublicAnswerStats | null,
  myAnswerIdSnap: string | null,
  myAnsweredAtSnap: number | null,
  questionStartedAt: number | null,
  questionEndsAt: number | null,
  isDemo: boolean,
  answers: { id: AnswerId; text: string }[] | null
) {
  stopTimer();
  const container = document.getElementById("result-content");
  if (!container) return;

  const correctIds = getCorrectAnswerIds(result);
  const isCorrect =
    myAnswerIdSnap !== null && correctIds.includes(myAnswerIdSnap as AnswerId);
  const skipped = !myAnswerIdSnap;

  // Calculate points client-side (mirrors host calculation for display)
  // For demo: computed but shown as "solo esempio" — does not affect real score
  let points = 0;
  if (!skipped && questionStartedAt && questionEndsAt && myAnsweredAtSnap) {
    points = calculatePoints({
      isCorrect,
      answeredAt: myAnsweredAtSnap,
      questionStartedAt,
      questionEndsAt,
    });
  }

  // Summary
  let summaryClass: string;
  let icon: string;
  let outcomeText: string;
  let outcomeColor: string;

  const allCorrect = correctIds.length === 4; // tutte le risposte corrette (Q leone_001)

  if (skipped) {
    summaryClass = "skip";
    icon = "⏱️";
    outcomeText = "Tempo scaduto!";
    outcomeColor = "#5A6654";
  } else if (allCorrect) {
    summaryClass = "correct";
    icon = "✅";
    outcomeText = "Tutti corretti! Era una domanda speciale 🦁";
    outcomeColor = "#3A5A35";
  } else if (isCorrect) {
    summaryClass = "correct";
    icon = "✅";
    outcomeText = "Giusto! Leone approva 🦁";
    outcomeColor = "#3A5A35";
  } else {
    summaryClass = "wrong";
    icon = "❌";
    outcomeText = "Peccato, quasi!";
    outcomeColor = "#A24438";
  }

  const ptsHTML =
    !skipped
      ? `<p class="result-pts ${points >= 0 ? "positive" : "negative"}">${points >= 0 ? "+" : ""}${points.toLocaleString("it-IT")} pt${isDemo ? `<span style="font-size:13px;font-weight:400;color:#7C8A76"> (solo esempio)</span>` : ""}</p>`
      : "";

  const summaryHTML = `
    <div class="result-summary ${summaryClass}">
      <span class="result-icon">${icon}</span>
      <p class="result-outcome" style="color:${outcomeColor}">${outcomeText}</p>
      ${ptsHTML}
    </div>`;

  // Distribution rows: A | risposte | percentuale + barra
  const ids = ["A", "B", "C", "D"] as const;
  const total = stats?.total ?? 0;

  const barsHTML = stats
    ? `<div class="stats-section">
        <p class="stats-title">Come ha risposto la sala</p>
        <div class="stats-list">
        ${ids
          .map((id) => {
            const count = stats[id] ?? 0;
            const pct = total > 0 ? Math.round((count / total) * 100) : 0;
            const isThisCorrect = correctIds.includes(id);
            const isMyWrongAnswer = id === myAnswerIdSnap && !isCorrect;
            const fillClass = isThisCorrect ? "f-correct" : isMyWrongAnswer ? "f-mine" : "";
            const rowClass = `${isThisCorrect ? "is-correct" : ""} ${id === myAnswerIdSnap ? "is-mine" : ""}`.trim();
            const votes = `${count} ${count === 1 ? "risposta" : "risposte"}`;
            return `<div class="ans-row ${rowClass}">
              <div class="ans-head">
                <span class="ans-badge b-${id}">${id}</span>
                <span class="ans-name">Risposta ${id}</span>
                <span class="ans-votes">${votes}</span>
                <span class="ans-pct">${pct}%</span>
              </div>
              <div class="ans-bar">
                <div class="ans-fill ${fillClass}" style="width:${pct}%"></div>
              </div>
            </div>`;
          })
          .join("")}
        </div>
      </div>`
    : "";

  // Correct-answer reveal panel (lettera + testo) + spiegazione
  const answerText = (id: AnswerId): string =>
    answers?.find((a) => a.id === id)?.text ?? "";

  let correctBodyHTML: string;
  if (allCorrect) {
    correctBodyHTML = `<div class="cp-all">Tutte le risposte erano valide 🦁 — era la domanda jolly!</div>`;
  } else {
    correctBodyHTML = `<div class="cp-answers">
      ${correctIds
        .map(
          (id) =>
            `<div class="cp-answer">
              <span class="cp-letter b-${id}">${id}</span>
              <span class="cp-text">${answerText(id as AnswerId)}</span>
            </div>`
        )
        .join("")}
    </div>`;
  }

  const explHTML = result.explanation
    ? `<p class="cp-expl">${result.explanation}</p>`
    : "";

  const correctPanelHTML =
    correctIds.length > 0
      ? `<div class="correct-panel">
          <div class="cp-head"><span>✅</span> ${allCorrect ? "Domanda speciale" : correctIds.length > 1 ? "Risposte corrette" : "Risposta corretta"}</div>
          ${correctBodyHTML}
          ${explHTML}
        </div>`
      : result.explanation
      ? `<div class="correct-panel"><p class="cp-expl" style="border:0;margin:0;padding:0">${result.explanation}</p></div>`
      : "";

  container.innerHTML = summaryHTML + barsHTML + correctPanelHTML;
  showScreen("result");
}

function renderQuestionLeaderboard(
  entries: PublicQuestionLeaderboardEntry[],
  kickedUids: Record<string, boolean> = {},
  kickedUsernames: Record<string, string> = {}
) {
  const listEl = document.getElementById("question-leaderboard-list");
  if (!listEl) return;

  const kickedNames = new Set(Object.values(kickedUsernames));
  const visibleEntries = entries.filter(
    (entry) => !(entry.uid && kickedUids[entry.uid]) && !kickedNames.has(entry.username)
  );

  if (visibleEntries.length === 0) {
    listEl.innerHTML = `<li class="lb-item lb-hidden"><span class="lb-copy"><span class="lb-name">Ancora nessuna classifica disponibile</span></span></li>`;
    showScreen("question-leaderboard");
    return;
  }

  listEl.innerHTML = visibleEntries.slice(0, 10).map((entry, i) => {
    const rank = i + 1;
    const isMe = entry.username === currentUsername;
    const medal = rank === 1 ? "🥇" : rank === 2 ? "🥈" : rank === 3 ? "🥉" : `${rank}.`;
    const answerClass = entry.answerId ? `answer-${entry.answerId}` : "skip";
    const outcomeClass = entry.isCorrect ? "correct" : entry.answerId ? "wrong" : "skip";
    const outcomeLabel = entry.isCorrect ? "Corretta" : entry.answerId ? "Sbagliata" : "Saltata";
    const pointsLabel = `${entry.points >= 0 ? "+" : ""}${entry.points.toLocaleString("it-IT")} pt`;

    return `<li class="lb-item ${rank <= 3 ? `rank${rank}` : ""} ${isMe ? "me" : ""}">
      <span class="lb-rank">${medal}</span>
      <div class="lb-copy">
        <span class="lb-name">${entry.username}${isMe ? " (tu)" : ""}</span>
        <span class="lb-sub">${formatResponseTime(entry.responseMs)}</span>
        <div class="lb-tags">
          <span class="lb-pill ${answerClass}">${entry.answerId ?? "-"}</span>
          <span class="lb-pill ${outcomeClass}">${outcomeLabel}</span>
        </div>
      </div>
      <span class="lb-score">${pointsLabel}</span>
    </li>`;
  }).join("");

  showScreen("question-leaderboard");
}

// ── Render leaderboard with progressive reveal ─────────────────────────────
async function renderLeaderboard(
  revealStep: number,
  isFinished = false,
  kickedUids: Record<string, boolean> = {},
  kickedUsernames: Record<string, string> = {}
) {
  const listEl = document.getElementById("leaderboard-list");
  if (!listEl) return;

  const snap = await get(ref(db, `leaderboards/${GAME_ID}`));
  const raw = snap.val() as Record<string, LeaderboardEntry> | null;

  const kickedNames = new Set(Object.values(kickedUsernames));
  const visibleRaw = raw
    ? Object.fromEntries(
        Object.entries(raw).filter(
          ([uid, entry]) => !kickedUids[uid] && !kickedNames.has(entry.username)
        )
      ) as Record<string, LeaderboardEntry>
    : null;

  if (!visibleRaw || Object.keys(visibleRaw).length === 0) {
    listEl.innerHTML = `<li style="text-align:center;color:#7C8A76;padding:12px">Ancora nessun punteggio</li>`;
    if (isFinished) {
      showScreen("finished");
    } else {
      showScreen("leaderboard");
    }
    return;
  }

  const sorted = Object.entries(visibleRaw).sort(([, a], [, b]) => b.score - a.score);
  const total = sorted.length;

  if (isFinished) {
    // All entries visible + show finished screen
    listEl.innerHTML = sorted
      .slice(0, 10)
      .map(([uid, entry], i) => {
        const rank = i + 1;
        const isMe = uid === currentUid;
        const medal = rank === 1 ? "🥇" : rank === 2 ? "🥈" : rank === 3 ? "🥉" : `${rank}.`;
        return `<li class="lb-item ${rank <= 3 ? `rank${rank}` : ""} ${isMe ? "me" : ""}">
          <span class="lb-rank">${medal}</span>
          <span class="lb-copy"><span class="lb-name">${entry.username}${isMe ? " (tu)" : ""}</span></span>
          <span class="lb-score">${entry.score.toLocaleString("it-IT")}</span>
        </li>`;
      })
      .join("");

    const myRank = sorted.findIndex(([uid]) => uid === currentUid) + 1;
    const myEntry = sorted.find(([uid]) => uid === currentUid);
    const rankEl = document.getElementById("final-rank");
    const scoreEl = document.getElementById("final-score");
    if (rankEl) rankEl.textContent = myRank > 0 ? `#${myRank}` : "—";
    if (scoreEl && myEntry)
      scoreEl.textContent = `${myEntry[1].score.toLocaleString("it-IT")} punti`;

    showScreen("finished");
    return;
  }

  // Progressive reveal:
  // revealStep 0 → show rank 6+ (startIndex = 5)
  // revealStep 1 → show rank 5+ (startIndex = 4)
  // revealStep 5 → show all     (startIndex = 0)
  const startIndex = Math.max(0, Math.min(total, 5 - revealStep));
  const visibleEntries = sorted.slice(startIndex);

  let html = "";

  if (startIndex > 0) {
    html += `<li class="lb-item lb-hidden">
      <span class="lb-rank">🎭</span>
      <span class="lb-copy"><span class="lb-name" style="color:#7C8A76;font-style:italic">Top ${startIndex} ancora nascosta…</span></span>
    </li>`;
  }

  html += visibleEntries
    .map(([uid, entry], i) => {
      const rank = startIndex + i + 1;
      const isMe = uid === currentUid;
      const medal = rank === 1 ? "🥇" : rank === 2 ? "🥈" : rank === 3 ? "🥉" : `${rank}.`;
      return `<li class="lb-item ${rank <= 3 ? `rank${rank}` : ""} ${isMe ? "me" : ""}">
        <span class="lb-rank">${medal}</span>
        <span class="lb-copy"><span class="lb-name">${entry.username}${isMe ? " (tu)" : ""}</span></span>
        <span class="lb-score">${entry.score.toLocaleString("it-IT")}</span>
      </li>`;
    })
    .join("");

  listEl.innerHTML = html;

  const waitingEl = document.getElementById("lb-waiting-msg");
  if (waitingEl) {
    waitingEl.textContent =
      revealStep >= 5
        ? "⏳ Prossima domanda in arrivo…"
        : "🎭 L'host sta rivelando la classifica…";
  }

  showScreen("leaderboard");
}

// ── Restore answer from Firebase after F5 / reconnect ─────────────────────
async function restoreAnswerIfNeeded(questionId: string): Promise<void> {
  // If both the question and the session are unchanged, nothing to do
  if (lastQuestionId === questionId && lastGameSession === currentGameSession) return;

  lastQuestionId = questionId;
  lastGameSession = currentGameSession;
  currentQuestionId = questionId;
  hasAnswered = false;
  myAnswerId = null;
  myAnsweredAt = null;

  if (!currentUid) return;

  try {
    const playerSnap = await get(ref(db, `players/${GAME_ID}/${currentUid}`));
    if (playerSnap.exists()) {
      const player = playerSnap.val() as {
        currentAnswerGameSession?: string;
        currentAnswerQuestionId?: string;
        currentAnswerAnswerId?: string;
        currentAnswerAnsweredAt?: number;
      };

      if (
        player.currentAnswerGameSession === currentGameSession &&
        player.currentAnswerQuestionId === questionId &&
        player.currentAnswerAnswerId
      ) {
        const ans = {
          answerId: player.currentAnswerAnswerId,
          answeredAt: player.currentAnswerAnsweredAt ?? null,
        };

        hasAnswered = true;
        myAnswerId = ans.answerId as typeof myAnswerId;
        myAnsweredAt = ans.answeredAt;
      }
    }
  } catch {
    // network error — keep defaults
  }
}

// ── Game state handler ─────────────────────────────────────────────────────
async function handleGameState(game: GameState) {
  // Espulso dall'host: chiudi la sessione e torna alla schermata di ingresso.
  if (currentUid && game.kickedUids && game.kickedUids[currentUid]) {
    stopTimer();
    clearSession();
    if (gameUnsubscribe) { gameUnsubscribe(); gameUnsubscribe = null; }
    currentUsername = null;
    const input = document.getElementById("input-username") as HTMLInputElement | null;
    if (input) input.value = "";
    const errEl = document.getElementById("join-error");
    if (errEl) errEl.textContent = "L'host ti ha rimosso dalla partita.";
    showScreen("join");
    return;
  }

  // Sync game session; on session change reset per-question cache so
  // restoreAnswerIfNeeded fetches fresh answers from the new path.
  if (game.gameSession && game.gameSession !== currentGameSession) {
    currentGameSession = game.gameSession;
    lastQuestionId = null;
    lastGameSession = null;
  }

  switch (game.status) {
    case "lobby":
      stopTimer();
      showScreen("lobby");
      break;

    case "demo":
    case "question": {
      const pq = game.publicCurrentQuestion;
      if (!pq) return;

      const isNew = pq.id !== lastQuestionId;
      if (isNew) {
        await restoreAnswerIfNeeded(pq.id);
      }

      // Question not yet revealed: show preview
      if (!game.questionVisible) {
        showPreview(pq);
        break;
      }

      // Question visible: show it
      if (isNew) {
        renderQuestion(
          pq,
          game.questionEndsAt!,
          hasAnswered ? { disabled: true, selectedId: myAnswerId } : {}
        );
      } else if (!hasAnswered) {
        if (!document.getElementById("screen-question")?.classList.contains("active")) {
          renderQuestion(pq, game.questionEndsAt!);
        }
      }
      // hasAnswered + same question → already showing question with selection; no re-render
      break;
    }

    case "locked": {
      const pq = game.publicCurrentQuestion;
      if (!pq) break;

      if (pq.id !== lastQuestionId) {
        await restoreAnswerIfNeeded(pq.id);
      }

      stopTimer();
      const timerEl = document.getElementById("question-timer");
      if (timerEl) { timerEl.textContent = "0"; timerEl.classList.add("urgent"); }

      // Ensure all buttons are disabled and selection is shown
      (["A", "B", "C", "D"] as const).forEach((id) => {
        const b = document.getElementById(`btn-${id}`) as HTMLButtonElement | null;
        if (b) {
          b.disabled = true;
          b.classList.toggle("selected", myAnswerId === id);
        }
      });

      if (!document.getElementById("screen-question")?.classList.contains("active")) {
        renderQuestion(pq, 0, { disabled: true, selectedId: myAnswerId });
      }
      break;
    }

    case "answer": {
      const pq = game.publicCurrentQuestion;
      if (pq && pq.id !== lastQuestionId) {
        await restoreAnswerIfNeeded(pq.id);
      }
      if (game.showResults && game.publicCurrentResult) {
        renderResult(
          game.publicCurrentResult,
          game.showStats ? (game.publicAnswerStats ?? null) : null,
          myAnswerId,
          myAnsweredAt,
          game.questionStartedAt,
          game.questionEndsAt,
          pq?.category === "demo",
          pq?.answers ?? null
        );
      }
      break;
    }

    case "question-leaderboard": {
      const pq = game.publicCurrentQuestion;
      if (pq && pq.id !== lastQuestionId) {
        await restoreAnswerIfNeeded(pq.id);
      }
      renderQuestionLeaderboard(
        game.publicQuestionLeaderboard ?? [],
        game.kickedUids ?? {},
        game.kickedUsernames ?? {}
      );
      break;
    }

    case "leaderboard":
      if (game.showLeaderboard && game.leaderboardRevealStep >= 0) {
        renderLeaderboard(
          game.leaderboardRevealStep,
          false,
          game.kickedUids ?? {},
          game.kickedUsernames ?? {}
        );
      }
      break;

    case "finished":
      renderLeaderboard(99, true, game.kickedUids ?? {}, game.kickedUsernames ?? {});
      break;
  }
}

// ── Setup Firebase listener ────────────────────────────────────────────────
function startListening() {
  const gameRef = ref(db, `games/${GAME_ID}`);
  const unsub = onValue(gameRef, (snap) => {
    if (!snap.exists()) return;
    handleGameState(snap.val() as GameState).catch(console.error);
  });
  gameUnsubscribe = unsub;
}

// ── Answer click ───────────────────────────────────────────────────────────
function bindAnswerButtons() {
  const ids = ["A", "B", "C", "D"] as const;
  ids.forEach((id) => {
    const btn = document.getElementById(`btn-${id}`);
    btn?.addEventListener("click", async () => {
      if (hasAnswered || !currentUid || !currentQuestionId) return;

      // Record answer locally before async submit
      hasAnswered = true;
      myAnswerId = id;
      myAnsweredAt = Date.now();

      // Disable all buttons and highlight selected — stay on question screen.
      // NON fermiamo il timer: continua a girare così tutti vedono quanto tempo rimane.
      ids.forEach((bid) => {
        const b = document.getElementById(`btn-${bid}`) as HTMLButtonElement | null;
        if (b) {
          b.disabled = true;
          b.classList.toggle("selected", bid === id);
        }
      });

      try {
        await submitAnswer(currentUid, currentGameSession!, currentQuestionId, id);
      } catch (err) {
        console.error("Errore nell'invio risposta:", err);
      }
    });
  });
}

// ── Join button ────────────────────────────────────────────────────────────
function bindJoinButton() {
  const btn = document.getElementById("btn-join") as HTMLButtonElement | null;
  const input = document.getElementById("input-username") as HTMLInputElement | null;
  const errorEl = document.getElementById("join-error");

  async function doJoin() {
    if (!btn || !input || !currentUid) return;
    const username = input.value.trim();

    if (username.length < 2) {
      if (errorEl) errorEl.textContent = "Il nome deve avere almeno 2 caratteri.";
      return;
    }
    if (username.length > 24) {
      if (errorEl) errorEl.textContent = "Il nome può avere al massimo 24 caratteri.";
      return;
    }

    if (errorEl) errorEl.textContent = "";
    btn.disabled = true;
    btn.textContent = "Sto entrando…";

    try {
      const taken = await checkUsernameTaken(username);
      if (taken) {
        if (errorEl) errorEl.textContent = "Questo nome è già in uso, scegline un altro!";
        btn.disabled = false;
        btn.textContent = "Entra nel gioco 🎮";
        return;
      }

      await joinGame(currentUid, username);
      setupPresence(currentUid);
      currentUsername = username;
      saveSession(currentUid, username);

      const lobbyEl = document.getElementById("lobby-username");
      if (lobbyEl) lobbyEl.textContent = username;

      startListening();
      showScreen("lobby");
    } catch (err) {
      console.error(err);
      if (errorEl) errorEl.textContent = "Errore di connessione. Riprova.";
      btn.disabled = false;
      btn.textContent = "Entra nel gioco 🎮";
    }
  }

  btn?.addEventListener("click", doJoin);
  input?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") doJoin();
  });
}

// ── Init ───────────────────────────────────────────────────────────────────
async function init() {
  bindAnswerButtons();
  bindJoinButton();

  try {
    const user = await ensureAnonymousUser();
    currentUid = user.uid;

    const session = loadSession();
    if (session && session.uid === currentUid) {
      // Reconnect: check if player is still in Firebase
      const snap = await get(ref(db, `players/${GAME_ID}/${currentUid}`));
      if (snap.exists()) {
        currentUsername = session.username;
        const lobbyEl = document.getElementById("lobby-username");
        if (lobbyEl) lobbyEl.textContent = currentUsername!;
        setupPresence(currentUid);
        startListening();
        showScreen("lobby");
        return;
      } else {
        clearSession();
      }
    }

    showScreen("join");
  } catch (err) {
    showError("Impossibile connettersi. Controlla la connessione e riprova.");
    console.error(err);
  }
}

init();
</script>

