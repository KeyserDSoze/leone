    const REPO_NAME  = 'leone';
    const LABEL      = 'battesimo-rsvp';
    const ISSUE_TITLE = 'RSVP Battesimo Leone \u2013 lista partecipanti';
    const API_BASE   = `https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}`;

    function decodeToken() {
        try { return atob(atob(GITHUB_TOKEN)); } catch { return ''; }
    }
    function authHeaders() {
        return {
            'Authorization': `token ${decodeToken()}`,
            'Accept': 'application/vnd.github.v3+json'
        };
    }

    function esc(s) {
        return String(s ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;');
    }

    function formatTimestamp(ts) {
        if (!ts) return '';
        try {
            return new Date(ts).toLocaleString('it-IT', {
                day: '2-digit', month: '2-digit', year: 'numeric',
                hour: '2-digit', minute: '2-digit'
            });
        } catch { return ts; }
    }

    async function load() {
        const statusEl = document.getElementById('status');
        const listEl   = document.getElementById('list');
        const btn      = document.getElementById('refreshBtn');
        const summaryBar = document.getElementById('summaryBar');

        btn.disabled = true;
        statusEl.style.display = 'block';
        statusEl.textContent = 'Caricamento in corso…';
        listEl.innerHTML = '';

        try {
            const res = await fetch(
                `${API_BASE}/issues?state=open&labels=${encodeURIComponent(LABEL)}&per_page=10`,
                { headers: authHeaders() }
            );
            if (!res.ok) throw new Error(`GitHub API error: ${res.status}`);
            const issues = await res.json();
            const issue = issues.find(i => i.title === ISSUE_TITLE);

            if (!issue) {
                statusEl.textContent = 'Nessun RSVP ricevuto ancora.';
                btn.disabled = false;
                return;
            }

            let list = [];
            try {
                const parsed = JSON.parse(issue.body ?? '[]');
                if (Array.isArray(parsed)) list = parsed;
            } catch { list = []; }

            if (list.length === 0) {
                statusEl.textContent = 'Nessun RSVP ricevuto ancora.';
                summaryBar.style.display = 'none';
                btn.disabled = false;
                return;
            }

            // Totals
            const totPersone = list.reduce((s, e) => s + (Number(e.numeroPersone) || 0), 0);
            const totBambini = list.reduce((s, e) => s + (Number(e.bambini) || 0), 0);
            document.getElementById('totFamiglie').textContent = list.length;
            document.getElementById('totPersone').textContent  = totPersone;
            document.getElementById('totBambini').textContent  = totBambini;
            document.getElementById('totAdulti').textContent   = totPersone - totBambini;
            summaryBar.style.display = 'flex';
            statusEl.style.display = 'none';

            // Cards
            listEl.innerHTML = list.map((e, idx) => {
                const hasBambini   = Number(e.bambini) > 0;
                const hasIntoll    = Array.isArray(e.intolleranti) && e.intolleranti.length > 0;
                const hasNote      = e.note && e.note.trim();

                const intolleranti = hasIntoll
                    ? e.intolleranti.map(p => {
                        const tags = (p.allergeni ?? []).map(a => `<span class="allergen-tag">${esc(a)}</span>`).join('');
                        const altri = p.altriAllergeni ? `<span class="allergen-tag">${esc(p.altriAllergeni)}</span>` : '';
                        const bambino = p.bambino ? ' <em>(bambino)</em>' : '';
                        return `<div class="person-row">
                            <div class="person-row-name">${esc(p.nome)}${bambino}</div>
                            <div>${tags}${altri}</div>
                        </div>`;
                    }).join('')
                    : '';

                return `<div class="card">
                    <div class="card-header">
                        <span class="card-name">${idx + 1}. ${esc(e.referente)}</span>
                        <div style="display:flex;gap:0.4rem;flex-wrap:wrap;align-items:center">
                            <span class="badge badge-people"><i class="fa-solid fa-users"></i> ${esc(e.numeroPersone)} pers.</span>
                            ${hasBambini ? `<span class="badge badge-bambini"><i class="fa-solid fa-baby"></i> ${esc(e.bambini)} bamb.</span>` : ''}
                            <span class="badge badge-time"><i class="fa-regular fa-clock"></i> ${esc(formatTimestamp(e.timestamp))}</span>
                        </div>
                    </div>
                    ${hasNote ? `<div class="card-detail"><strong>Note:</strong> ${esc(e.note)}</div>` : ''}
                    ${hasIntoll ? `<div class="card-detail" style="margin-top:0.6rem"><strong>Intolleranze:</strong>${intolleranti}</div>` : ''}
                </div>`;
            }).join('');

        } catch (err) {
            statusEl.style.display = 'block';
            statusEl.textContent = `Errore: ${err.message}`;
        }

        btn.disabled = false;
    }

    document.getElementById('refreshBtn').addEventListener('click', load);
    load();
})();
</script>
</body>
</html>
