---
import { createUrl } from '../utils/urls';
---

<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Battesimo di Leone – 7 Giugno 2026</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Alex+Brush&family=Cormorant+Garamond:wght@300;400;600&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <style is:global>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Montserrat', sans-serif;
            background: #dbeafe;
            color: #1e293b;
            min-height: 100vh;
        }

        /* ── INVITATION ── */
        .invite-wrapper {
            min-height: 100vh;
            background: linear-gradient(160deg, #e8f4fb 0%, #d6eaf8 60%, #cce0f5 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem 1.5rem 4rem;
            position: relative;
        }

        .btn-home {
            position: absolute;
            top: 1.2rem;
            left: 1.2rem;
            color: #5a8fa8;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            letter-spacing: 0.04em;
            transition: color 0.2s;
        }
        .btn-home:hover { color: #2c6284; }

        .lion-img {
            width: min(260px, 65vw);
            height: auto;
            margin-bottom: 2rem;
            drop-shadow: drop-shadow(0 8px 24px rgba(0,0,0,0.15));
            filter: drop-shadow(0 6px 18px rgba(0,0,0,0.12));
        }

        .invite-tagline {
            font-family: 'Cormorant Garamond', serif;
            font-weight: 300;
            font-size: clamp(1rem, 3vw, 1.2rem);
            letter-spacing: 0.1em;
            color: #4a6a80;
            margin-bottom: 0.5rem;
        }

        .invite-title {
            font-family: 'Cormorant Garamond', serif;
            font-weight: 600;
            font-size: clamp(1.5rem, 5vw, 2.4rem);
            letter-spacing: 0.25em;
            color: #1e293b;
            text-transform: uppercase;
            margin-bottom: 0.2rem;
        }

        .invite-name {
            font-family: 'Alex Brush', cursive;
            font-size: clamp(5.5rem, 20vw, 10rem);
            color: #7aabcf;
            line-height: 1;
            margin-bottom: 1rem;
            margin-top: 0.5rem;
        }

        .date-block {
            text-align: center;
            margin-bottom: 2rem;
        }

        .date-month {
            font-family: 'Montserrat', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            letter-spacing: 0.35em;
            color: #4a6a80;
            text-transform: uppercase;
            margin-bottom: 0.6rem;
        }

        .date-row {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1.8rem;
            max-width: 380px;
            margin: 0 auto;
        }

        .date-side {
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.25em;
            color: #4a6a80;
            text-transform: uppercase;
            text-align: center;
            border-top: 1.5px solid #4a6a80;
            border-bottom: 1.5px solid #4a6a80;
            padding: 5px 0;
            width: 90px;
            flex-shrink: 0;
        }

        .date-day {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(3rem, 10vw, 5rem);
            font-weight: 300;
            color: #7aabcf;
            line-height: 1;
            position: relative;
            top: -0.3em;
        }

        .date-year {
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.35em;
            color: #4a6a80;
            text-transform: uppercase;
            margin-top: 0.5rem;
            position: relative;
            top: -1em;
        }

        .venue-block {
            text-align: center;
            font-size: clamp(0.78rem, 2.2vw, 0.92rem);
            font-weight: 300;
            letter-spacing: 0.08em;
            color: #2c5168;
            line-height: 2;
        }

        .venue-name {
            font-weight: 600;
        }

        .maps-link {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            margin-top: 1.2rem;
            color: #2c82b0;
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-decoration: none;
            border: 1px solid #7aabcf;
            padding: 0.45rem 1rem;
            border-radius: 2rem;
            transition: all 0.25s;
        }
        .maps-link:hover {
            background: #7aabcf;
            color: #fff;
        }

        .cta-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            margin-top: 2.5rem;
            background: linear-gradient(135deg, #7aabcf, #4a8ab5);
            color: #fff;
            font-family: 'Montserrat', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            padding: 1rem 2.5rem;
            border-radius: 2rem;
            text-decoration: none;
            box-shadow: 0 4px 18px rgba(74, 138, 181, 0.35);
            transition: all 0.3s;
        }
        .cta-btn:hover {
            background: linear-gradient(135deg, #4a8ab5, #2c6284);
            transform: translateY(-2px);
            box-shadow: 0 7px 24px rgba(44, 98, 132, 0.4);
        }

        /* ── RSVP SECTION ── */
        .rsvp-wrapper {
            background: linear-gradient(160deg, #c8dff0 0%, #d6eaf8 100%);
            padding: 4rem 1.5rem 5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .rsvp-card {
            background: rgba(255,255,255,0.92);
            border-radius: 1.5rem;
            padding: 2.5rem 2rem;
            max-width: 580px;
            width: 100%;
            box-shadow: 0 8px 32px rgba(74, 138, 181, 0.15);
        }

        .rsvp-title {
            font-family: 'Cormorant Garamond', serif;
            font-weight: 600;
            font-size: clamp(1.5rem, 5vw, 2rem);
            letter-spacing: 0.15em;
            text-align: center;
            color: #1e293b;
            margin-bottom: 0.4rem;
        }

        .rsvp-subtitle {
            text-align: center;
            font-size: 0.88rem;
            color: #5a8fa8;
            margin-bottom: 2rem;
            letter-spacing: 0.04em;
        }

        .form-group {
            margin-bottom: 1.4rem;
        }

        .form-group > label {
            display: block;
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #4a6a80;
            margin-bottom: 0.45rem;
        }

        .form-group input[type="text"],
        .form-group input[type="number"],
        .form-group textarea {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1.5px solid #b8d4e8;
            border-radius: 0.75rem;
            font-size: 0.97rem;
            font-family: 'Montserrat', sans-serif;
            background: #f7fbff;
            color: #1e293b;
            transition: border-color 0.25s, box-shadow 0.25s;
        }
        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #7aabcf;
            box-shadow: 0 0 0 3px rgba(122, 171, 207, 0.2);
        }

        .form-group textarea {
            min-height: 90px;
            resize: vertical;
        }

        .allergens-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 0.5rem;
        }

        .allergen-label {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.88rem;
            font-weight: 400;
            text-transform: none;
            letter-spacing: 0;
            color: #334155;
            cursor: pointer;
            padding: 0.4rem 0.6rem;
            border: 1.5px solid #c8dff0;
            border-radius: 0.75rem;
            background: #f7fbff;
            transition: all 0.2s;
            user-select: none;
        }
        .allergen-label input[type="checkbox"] {
            width: 1rem;
            height: 1rem;
            accent-color: #7aabcf;
            cursor: pointer;
            flex-shrink: 0;
        }
        .allergen-label:has(input:checked) {
            background: #dbeafe;
            border-color: #7aabcf;
            color: #1e4f6a;
            font-weight: 600;
        }

        .submit-btn {
            width: 100%;
            margin-top: 0.5rem;
            padding: 1rem;
            background: linear-gradient(135deg, #7aabcf, #4a8ab5);
            color: #fff;
            font-family: 'Montserrat', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            border: none;
            border-radius: 2rem;
            cursor: pointer;
            box-shadow: 0 4px 18px rgba(74, 138, 181, 0.3);
            transition: all 0.3s;
        }
        .submit-btn:hover:not(:disabled) {
            background: linear-gradient(135deg, #4a8ab5, #2c6284);
            transform: translateY(-2px);
        }
        .submit-btn:disabled {
            background: #b8d4e8;
            cursor: not-allowed;
            transform: none;
        }

        /* Toast */
        .toast {
            position: fixed;
            top: 1.5rem;
            right: 1.5rem;
            padding: 1rem 1.8rem;
            border-radius: 1rem;
            font-weight: 600;
            font-size: 0.95rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            z-index: 9999;
            display: none;
            align-items: center;
            gap: 0.6rem;
            opacity: 1;
            transition: opacity 0.3s;
        }
        .toast-success {
            background: #d1fae5;
            color: #065f46;
            border: 1px solid #6ee7b7;
        }
        .toast-error {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        /* ── Allergen section ── */
        .allergen-section {
            border: 1.5px solid #b8d4e8;
            border-radius: 1rem;
            padding: 1.2rem 1rem 1rem;
            margin-bottom: 1.4rem;
            background: #f0f8ff;
        }
        .allergen-section-title {
            font-size: 0.82rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #4a6a80;
            margin-bottom: 0.3rem;
        }
        .allergen-section-hint {
            font-size: 0.82rem;
            color: #5a8fa8;
            font-style: italic;
            margin-bottom: 1rem;
            line-height: 1.5;
        }
        .add-person-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            margin-top: 0.4rem;
            padding: 0.55rem 1.2rem;
            border: 1.5px solid #7aabcf;
            border-radius: 2rem;
            background: #fff;
            color: #2c82b0;
            font-family: 'Montserrat', sans-serif;
            font-size: 0.85rem;
            font-weight: 700;
            letter-spacing: 0.05em;
            cursor: pointer;
            transition: all 0.2s;
        }
        .add-person-btn:hover { background: #7aabcf; color: #fff; }

        /* ── Person cards ── */
        .person-card {
            border: 1.5px solid #b8d4e8;
            border-radius: 1rem;
            padding: 1.1rem 1rem 0.4rem;
            margin-bottom: 1rem;
            background: #eef6fd;
        }

        .person-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 0.85rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid #b8d4e8;
        }
        .person-number {
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: #4a8ab5;
        }
        .person-remove-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: #94a3b8;
            font-size: 1rem;
            line-height: 1;
            padding: 0.15rem 0.4rem;
            border-radius: 0.4rem;
            transition: color 0.2s, background 0.2s;
        }
        .person-remove-btn:hover { color: #dc2626; background: #fee2e2; }

        .person-card .form-group { margin-bottom: 0.9rem; }

        .invite-guests {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(1rem, 3.5vw, 1.4rem);
            font-weight: 400;
            font-style: italic;
            color: #4a6a80;
            letter-spacing: 0.06em;
            text-align: center;
            margin-bottom: 1.2rem;
        }

        /* Responsive */
        @media (max-width: 480px) {
            .invite-name  { font-size: 4.5rem; }
            .date-side    { width: 70px; }
            .rsvp-card    { padding: 1.8rem 1.2rem; }
            .allergens-grid { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>

<!-- ══════════════ INVITATION ══════════════ -->
<section class="invite-wrapper">
    <a href={createUrl("/")} class="btn-home">
        <i class="fa-solid fa-arrow-left"></i> Home
    </a>

    <img src="/images/leone-lion.png" alt="Leone" class="lion-img" />

    <p class="invite-tagline">Con gioia vi invitiamo al</p>
    <h2 class="invite-title">Battesimo di</h2>
    <h1 class="invite-name">Leone</h1>
    <p id="inviteGuests" class="invite-guests" style="display:none"></p>

    <div class="date-block">
        <p class="date-month">Giugno</p>
        <div class="date-row">
            <span class="date-side">Domenica</span>
            <span class="date-day">7</span>
            <span class="date-side">Ore 11</span>
        </div>
        <p class="date-year">2026</p>
    </div>

    <div class="divider"></div>

    <div class="venue-block">
        <a class="maps-link" href="https://maps.app.goo.gl/46sgG2RNgayqA6sg9" target="_blank" rel="noopener noreferrer">
            <i class="fa-solid fa-location-dot"></i> Duomo di San Lorenzo – Piazza San Lorenzo, Viterbo
        </a>
        <div style="margin-top:0.7rem; font-size:0.78rem; color:#4a6a80; line-height:1.7;">
            <p>
                <a href="https://maps.app.goo.gl/ixo9ShuKB9d8vDKj7" target="_blank" rel="noopener noreferrer" style="color:#2c82b0; font-weight:600; text-decoration:none;">
                    <i class="fa-solid fa-square-parking"></i> Parcheggio più vicino
                </a>
                &nbsp;·&nbsp;
                <a href="https://maps.app.goo.gl/dmzcbHhek2wbqXE69" target="_blank" rel="noopener noreferrer" style="color:#2c82b0; font-weight:600; text-decoration:none;">
                    <i class="fa-solid fa-elevator"></i> Ascensore verso il Duomo
                </a>
            </p>
        </div>
        <p style="margin-top:1rem"><span class="venue-name">Casale Aderio</span></p>
        <p>Strada Teverina, Viterbo</p>
        <a class="maps-link" href="https://maps.app.goo.gl/LUo9YgAQv5HxvfiS6" target="_blank" rel="noopener noreferrer">
            <i class="fa-solid fa-location-dot"></i> Come raggiungere Casale Aderio
        </a>
    </div>

    <a href="#rsvp" class="cta-btn">
        <i class="fa-solid fa-check"></i> Conferma la tua presenza
    </a>
</section>

<!-- ══════════════ RSVP FORM ══════════════ -->
<section class="rsvp-wrapper" id="rsvp">
    <div class="rsvp-card">
        <h2 class="rsvp-title">Conferma Partecipazione</h2>
        <p class="rsvp-subtitle">Aiutaci a organizzare al meglio la giornata ✨</p>

        <form id="rsvpForm">
            <div class="form-group">
                <label for="rsvpName">Il tuo nome (referente) *</label>
                <input type="text" id="rsvpName" name="name" required maxlength="80"
                       placeholder="Nome e cognome">
            </div>

            <div class="form-group">
                <label for="rsvpPeople">Numero di persone che confermano *</label>
                <input type="number" id="rsvpPeople" name="people" required min="1" max="20"
                       placeholder="es. 2">
            </div>

            <div class="form-group">
                <label for="rsvpBambini">Di cui menù bambini</label>
                <input type="number" id="rsvpBambini" name="bambini" min="0" max="20"
                       placeholder="es. 1 (0 se nessuno)">
                <p style="font-size:0.78rem;color:#5a8fa8;font-style:italic;margin-top:0.35rem;">I neonati che non mangiano non vanno conteggiati</p>
            </div>

            <div class="form-group">
                <label for="rsvpNotes">Note aggiuntive</label>
                <textarea id="rsvpNotes" name="notes" maxlength="500"
                          placeholder="Qualcosa che dobbiamo sapere?"></textarea>
            </div>

            <div class="allergen-section">
                <p class="allergen-section-title">Intolleranze alimentari</p>
                <p class="allergen-section-hint">Se qualcuno del tuo gruppo ha intolleranze, aggiungilo qui con nome e allergie. Lascia vuoto se nessuno ne ha.</p>
                <div id="peopleContainer"></div>
                <button type="button" class="add-person-btn" id="addPersonBtn">
                    <i class="fa-solid fa-plus"></i>&nbsp; Aggiungi persona intollerante
                </button>
            </div>

            <button type="submit" class="submit-btn" id="submitBtn">
                <i class="fa-solid fa-paper-plane"></i>&nbsp; Conferma presenza
            </button>
        </form>
    </div>
</section>

<div id="toastSuccess" class="toast toast-success">
    <i class="fa-solid fa-circle-check"></i> Presenza confermata! Grazie, ci vediamo il 7 giugno! 🎉
</div>
<div id="toastError" class="toast toast-error">
    <i class="fa-solid fa-circle-xmark"></i> <span id="toastErrorMsg">Errore nell'invio, riprova.</span>
</div>

<script>
(function () {
    const GITHUB_TOKEN = 'WjJsMGFIVmlYM0JoZEY4eE1VRktWMVJhV0ZFd01HdHlkVTlSZGpOUlozRklYMVZuVDBObFdYVkVVMlo2ZEVsb1FtVkdNMjQ1ZDFab2RWSnBVbEZRVEZwVmRFMDJUR0p3ZEZneFRVRkxTVFJOVDFoQk5IcEhUa28wZGxkMg==';
    const REPO_OWNER = 'KeyserDSoze';
    const REPO_NAME  = 'leone';
    const LABEL      = 'battesimo-rsvp';
    const ISSUE_TITLE = 'RSVP Battesimo Leone \u2013 lista partecipanti';
    const API_BASE   = `https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}`;

    const ALLERGENS = ['Lattosio', 'Glutine', 'Nichel', 'Frutta secca', 'Pesce', 'Crostacei', 'Uova', 'Cipolla', 'Aglio'];

    function decodeToken(): string {
        try { return atob(atob(GITHUB_TOKEN)); } catch { return ''; }
    }

    function authHeaders(): Record<string, string> {
        return {
            'Authorization': `token ${decodeToken()}`,
            'Accept': 'application/vnd.github.v3+json',
            'Content-Type': 'application/json'
        };
    }

    interface GithubIssue { number: number; title: string; body: string | null; }
    interface PersonEntry { nome: string; bambino: boolean; allergeni: string[]; altriAllergeni: string; }
    interface RsvpEntry { referente: string; numeroPersone: number; bambini: number; intolleranti: PersonEntry[]; note: string; timestamp: string; }

    async function getOrCreateIssue(): Promise<GithubIssue> {
        const res = await fetch(
            `${API_BASE}/issues?state=open&labels=${encodeURIComponent(LABEL)}&per_page=10`,
            { headers: authHeaders() }
        );
        if (!res.ok) throw new Error(`GitHub API error: ${res.status}`);
        const issues: GithubIssue[] = await res.json();
        const existing = issues.find((i) => i.title === ISSUE_TITLE);
        if (existing) return existing;
        await ensureLabel();
        const create = await fetch(`${API_BASE}/issues`, {
            method: 'POST',
            headers: authHeaders(),
            body: JSON.stringify({ title: ISSUE_TITLE, body: '[]', labels: [LABEL] })
        });
        if (!create.ok) throw new Error(`Errore creazione issue: ${create.status}`);
        return create.json() as Promise<GithubIssue>;
    }

    async function ensureLabel(): Promise<void> {
        const check = await fetch(`${API_BASE}/labels/${encodeURIComponent(LABEL)}`, { headers: authHeaders() });
        if (check.status === 404) {
            await fetch(`${API_BASE}/labels`, {
                method: 'POST',
                headers: authHeaders(),
                body: JSON.stringify({ name: LABEL, color: '7aabcf', description: 'RSVP Battesimo Leone' })
            });
        }
    }

    async function submitRsvp(entry: RsvpEntry): Promise<void> {
        const issue = await getOrCreateIssue();
        let list: RsvpEntry[] = [];
        try {
            const parsed: unknown = JSON.parse(issue.body ?? '[]');
            if (Array.isArray(parsed)) list = parsed as RsvpEntry[];
        } catch { list = []; }
        list.push(entry);
        const update = await fetch(`${API_BASE}/issues/${issue.number}`, {
            method: 'PATCH',
            headers: authHeaders(),
            body: JSON.stringify({ body: JSON.stringify(list, null, 2) })
        });
        if (!update.ok) throw new Error(`Errore aggiornamento issue: ${update.status}`);
    }

    // ── Manual add/remove person cards ──
    let personCount = 0;

    function escapeAttr(s: string): string {
        return s.replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function renumberCards(): void {
        const container = document.getElementById('peopleContainer');
        if (!container) return;
        container.querySelectorAll<HTMLElement>('.person-number').forEach((el, idx) => {
            el.textContent = `Persona intollerante ${idx + 1}`;
        });
    }

    function addPersonCard(): void {
        const container = document.getElementById('peopleContainer');
        if (!container) return;
        personCount++;
        const card = document.createElement('div');
        card.className = 'person-card';
        card.innerHTML = `
            <div class="person-card-header">
                <span class="person-number">Persona intollerante ${personCount}</span>
                <button type="button" class="person-remove-btn" title="Rimuovi">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="form-group">
                <label>Nome</label>
                <input type="text" class="person-name" maxlength="80" placeholder="Nome e cognome">
            </div>
            <div class="form-group">
                <label class="allergen-label" style="display:inline-flex;border-color:#fbbf24;background:#fffbeb;">
                    <input type="checkbox" class="person-bambino"> Menù bambino
                </label>
            </div>
            <div class="form-group">
                <label>Intolleranze</label>
                <div class="allergens-grid">
                    ${ALLERGENS.map(a => `
                    <label class="allergen-label">
                        <input type="checkbox" class="person-allergen" value="${a}"> ${a}
                    </label>`).join('')}
                </div>
            </div>
            <div class="form-group">
                <label>Altre intolleranze</label>
                <input type="text" class="person-other-allergens" maxlength="200"
                       placeholder="es. arachidi, sulfiti\u2026">
            </div>`;
        card.querySelector('.person-remove-btn')?.addEventListener('click', () => {
            card.remove();
            renumberCards();
        });
        container.appendChild(card);
    }

    document.getElementById('addPersonBtn')?.addEventListener('click', addPersonCard);

    // ── Form submit ──
    const form = document.getElementById('rsvpForm') as HTMLFormElement | null;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement | null;

    form?.addEventListener('submit', async (e: Event) => {
        e.preventDefault();

        const referente = (document.getElementById('rsvpName') as HTMLInputElement).value.trim();
        const numeroPersone = parseInt((document.getElementById('rsvpPeople') as HTMLInputElement).value, 10);
        const bambini = parseInt((document.getElementById('rsvpBambini') as HTMLInputElement).value || '0', 10) || 0;
        const notes = (document.getElementById('rsvpNotes') as HTMLTextAreaElement).value.trim();

        if (!referente || !numeroPersone || numeroPersone < 1) {
            showToast('error', 'Compila nome e numero di persone.');
            return;
        }

        const intolleranti: PersonEntry[] = [];
        document.querySelectorAll<HTMLElement>('.person-card').forEach((card) => {
            const nome = (card.querySelector('.person-name') as HTMLInputElement)?.value.trim() ?? '';
            const bambino = (card.querySelector('.person-bambino') as HTMLInputElement)?.checked ?? false;
            const allergeni = Array.from(card.querySelectorAll<HTMLInputElement>('.person-allergen:checked')).map(c => c.value);
            const altriAllergeni = (card.querySelector('.person-other-allergens') as HTMLInputElement)?.value.trim() ?? '';
            intolleranti.push({ nome, bambino, allergeni, altriAllergeni });
        });

        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>&nbsp; Invio in corso\u2026';
        }

        try {
            await submitRsvp({ referente, numeroPersone, bambini, intolleranti, note: notes, timestamp: new Date().toISOString() });
            form?.reset();
            const container = document.getElementById('peopleContainer');
            if (container) container.innerHTML = '';
            showToast('success', '');
        } catch (err) {
            console.error(err);
            showToast('error', err instanceof Error ? err.message : 'Errore sconosciuto');
        } finally {
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fa-solid fa-paper-plane"></i>&nbsp; Conferma presenza';
            }
        }
    });

    function showToast(type: 'success' | 'error', msg: string): void {
        const el = document.getElementById(type === 'success' ? 'toastSuccess' : 'toastError');
        if (!el) return;
        if (type === 'error' && msg) {
            const errMsg = document.getElementById('toastErrorMsg');
            if (errMsg) errMsg.textContent = msg;
        }
        el.style.display = 'flex';
        el.style.opacity = '1';
        setTimeout(() => {
            el.style.opacity = '0';
            setTimeout(() => { el.style.display = 'none'; }, 350);
        }, 6000);
    }

    // ── Personalized invite from ?p= ──
    const INVITE_SECRET = 'battesimo-leone-2026';

    async function getInviteKey(): Promise<CryptoKey> {
        const enc = new TextEncoder();
        const keyMaterial = await crypto.subtle.importKey(
            'raw', enc.encode(INVITE_SECRET), 'PBKDF2', false, ['deriveKey']
        );
        return crypto.subtle.deriveKey(
            { name: 'PBKDF2', salt: enc.encode('leone-battesimo-salt'), iterations: 100000, hash: 'SHA-256' },
            keyMaterial,
            { name: 'AES-GCM', length: 256 },
            false,
            ['encrypt', 'decrypt']
        );
    }

    async function decryptInvite(encoded: string): Promise<string | null> {
        try {
            const b64 = encoded.replace(/-/g, '+').replace(/_/g, '/');
            const buf = Uint8Array.from(atob(b64), (c: string) => c.charCodeAt(0));
            const key = await getInviteKey();
            const plain = await crypto.subtle.decrypt(
                { name: 'AES-GCM', iv: buf.slice(0, 12) },
                key,
                buf.slice(12)
            );
            return new TextDecoder().decode(plain);
        } catch {
            return null;
        }
    }

    function capitalizeFirst(s: string): string {
        return s.charAt(0).toUpperCase() + s.slice(1).toLowerCase();
    }

    function titleCase(s: string): string {
        return s.trim().split(/\s+/).map(capitalizeFirst).join(' ');
    }

    function getFirstName(fullName: string): string {
        return capitalizeFirst(fullName.trim().split(/\s+/)[0]);
    }

    async function initPersonalizedInvite(): Promise<void> {
        const p = new URLSearchParams(window.location.search).get('p');
        if (!p) return;
        const plain = await decryptInvite(p);
        if (!plain) return;
        const parts = plain.split(',').map((s: string) => s.trim()).filter(Boolean);
        if (parts.length === 0) return;

        const guestsEl = document.getElementById('inviteGuests');
        if (guestsEl) {
            const firstNames = parts.map(getFirstName);
            const nameList = firstNames.length === 1
                ? firstNames[0]
                : firstNames.slice(0, -1).join(', ') + ' e ' + firstNames[firstNames.length - 1];
            guestsEl.textContent = `Cari ${nameList},`;
            guestsEl.style.display = 'block';
        }

        const nameInput = document.getElementById('rsvpName') as HTMLInputElement | null;
        const peopleInput = document.getElementById('rsvpPeople') as HTMLInputElement | null;
        if (nameInput) nameInput.value = titleCase(parts[0]);
        if (peopleInput) peopleInput.value = String(parts.length);
    }

    initPersonalizedInvite();
})();
</script>
</body>
</html>
