---
import { createUrl } from '../utils/urls';
---

<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Battesimo di Leone – 7 Giugno 2026</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Cormorant+Garamond:wght@300;400;600&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Montserrat', sans-serif;
            background: #dbeafe;
            color: #1e293b;
            min-height: 100vh;
        }

        /* ── INVITATION ── */
        .invite-wrapper {
            min-height: 100vh;
            background: linear-gradient(160deg, #e8f4fb 0%, #d6eaf8 60%, #cce0f5 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem 1.5rem 4rem;
            position: relative;
        }

        .btn-home {
            position: absolute;
            top: 1.2rem;
            left: 1.2rem;
            color: #5a8fa8;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            letter-spacing: 0.04em;
            transition: color 0.2s;
        }
        .btn-home:hover { color: #2c6284; }

        .lion-img {
            width: min(260px, 65vw);
            height: auto;
            margin-bottom: 2rem;
            drop-shadow: drop-shadow(0 8px 24px rgba(0,0,0,0.15));
            filter: drop-shadow(0 6px 18px rgba(0,0,0,0.12));
        }

        .invite-tagline {
            font-family: 'Cormorant Garamond', serif;
            font-weight: 300;
            font-size: clamp(1rem, 3vw, 1.2rem);
            letter-spacing: 0.1em;
            color: #4a6a80;
            margin-bottom: 0.5rem;
        }

        .invite-title {
            font-family: 'Cormorant Garamond', serif;
            font-weight: 600;
            font-size: clamp(1.5rem, 5vw, 2.4rem);
            letter-spacing: 0.25em;
            color: #1e293b;
            text-transform: uppercase;
            margin-bottom: 0.2rem;
        }

        .invite-name {
            font-family: 'Great Vibes', cursive;
            font-size: clamp(4rem, 14vw, 7rem);
            color: #7aabcf;
            line-height: 1;
            margin-bottom: 2rem;
        }

        .date-block {
            text-align: center;
            margin-bottom: 2rem;
        }

        .date-month {
            font-family: 'Montserrat', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            letter-spacing: 0.35em;
            color: #4a6a80;
            text-transform: uppercase;
            margin-bottom: 0.6rem;
        }

        .date-row {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            gap: 1.8rem;
            max-width: 380px;
            margin: 0 auto;
        }

        .date-side {
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.25em;
            color: #4a6a80;
            text-transform: uppercase;
            text-align: center;
            border-top: 1.5px solid #4a6a80;
            border-bottom: 1.5px solid #4a6a80;
            padding: 5px 0;
            justify-self: center;
            width: 100%;
        }

        .date-day {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(3rem, 10vw, 5rem);
            font-weight: 300;
            color: #1e293b;
            line-height: 1;
        }

        .date-year {
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.35em;
            color: #4a6a80;
            text-transform: uppercase;
            margin-top: 0.5rem;
        }

        .divider {
            width: 80px;
            height: 1px;
            background: #7aabcf;
            margin: 1.5rem auto;
        }

        .venue-block {
            text-align: center;
            font-size: clamp(0.78rem, 2.2vw, 0.92rem);
            font-weight: 300;
            letter-spacing: 0.08em;
            color: #2c5168;
            line-height: 2;
        }

        .venue-name {
            font-weight: 600;
        }

        .maps-link {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            margin-top: 1.2rem;
            color: #2c82b0;
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-decoration: none;
            border: 1px solid #7aabcf;
            padding: 0.45rem 1rem;
            border-radius: 2rem;
            transition: all 0.25s;
        }
        .maps-link:hover {
            background: #7aabcf;
            color: #fff;
        }

        .cta-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            margin-top: 2.5rem;
            background: linear-gradient(135deg, #7aabcf, #4a8ab5);
            color: #fff;
            font-family: 'Montserrat', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            padding: 1rem 2.5rem;
            border-radius: 2rem;
            text-decoration: none;
            box-shadow: 0 4px 18px rgba(74, 138, 181, 0.35);
            transition: all 0.3s;
        }
        .cta-btn:hover {
            background: linear-gradient(135deg, #4a8ab5, #2c6284);
            transform: translateY(-2px);
            box-shadow: 0 7px 24px rgba(44, 98, 132, 0.4);
        }

        /* ── RSVP SECTION ── */
        .rsvp-wrapper {
            background: linear-gradient(160deg, #c8dff0 0%, #d6eaf8 100%);
            padding: 4rem 1.5rem 5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .rsvp-card {
            background: rgba(255,255,255,0.92);
            border-radius: 1.5rem;
            padding: 2.5rem 2rem;
            max-width: 580px;
            width: 100%;
            box-shadow: 0 8px 32px rgba(74, 138, 181, 0.15);
        }

        .rsvp-title {
            font-family: 'Cormorant Garamond', serif;
            font-weight: 600;
            font-size: clamp(1.5rem, 5vw, 2rem);
            letter-spacing: 0.15em;
            text-align: center;
            color: #1e293b;
            margin-bottom: 0.4rem;
        }

        .rsvp-subtitle {
            text-align: center;
            font-size: 0.88rem;
            color: #5a8fa8;
            margin-bottom: 2rem;
            letter-spacing: 0.04em;
        }

        .form-group {
            margin-bottom: 1.4rem;
        }

        .form-group label {
            display: block;
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #4a6a80;
            margin-bottom: 0.45rem;
        }

        .form-group input[type="text"],
        .form-group input[type="number"],
        .form-group textarea {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1.5px solid #b8d4e8;
            border-radius: 0.75rem;
            font-size: 0.97rem;
            font-family: 'Montserrat', sans-serif;
            background: #f7fbff;
            color: #1e293b;
            transition: border-color 0.25s, box-shadow 0.25s;
        }
        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #7aabcf;
            box-shadow: 0 0 0 3px rgba(122, 171, 207, 0.2);
        }

        .form-group textarea {
            min-height: 90px;
            resize: vertical;
        }

        .allergens-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 0.5rem;
        }

        .allergen-label {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.88rem;
            font-weight: 400;
            text-transform: none;
            letter-spacing: 0;
            color: #334155;
            cursor: pointer;
            padding: 0.4rem 0.6rem;
            border: 1.5px solid #c8dff0;
            border-radius: 0.75rem;
            background: #f7fbff;
            transition: all 0.2s;
            user-select: none;
        }
        .allergen-label input[type="checkbox"] {
            width: 1rem;
            height: 1rem;
            accent-color: #7aabcf;
            cursor: pointer;
            flex-shrink: 0;
        }
        .allergen-label:has(input:checked) {
            background: #dbeafe;
            border-color: #7aabcf;
            color: #1e4f6a;
            font-weight: 600;
        }

        .submit-btn {
            width: 100%;
            margin-top: 0.5rem;
            padding: 1rem;
            background: linear-gradient(135deg, #7aabcf, #4a8ab5);
            color: #fff;
            font-family: 'Montserrat', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            border: none;
            border-radius: 2rem;
            cursor: pointer;
            box-shadow: 0 4px 18px rgba(74, 138, 181, 0.3);
            transition: all 0.3s;
        }
        .submit-btn:hover:not(:disabled) {
            background: linear-gradient(135deg, #4a8ab5, #2c6284);
            transform: translateY(-2px);
        }
        .submit-btn:disabled {
            background: #b8d4e8;
            cursor: not-allowed;
            transform: none;
        }

        /* Toast */
        .toast {
            position: fixed;
            top: 1.5rem;
            right: 1.5rem;
            padding: 1rem 1.8rem;
            border-radius: 1rem;
            font-weight: 600;
            font-size: 0.95rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            z-index: 9999;
            display: none;
            align-items: center;
            gap: 0.6rem;
            opacity: 1;
            transition: opacity 0.3s;
        }
        .toast-success {
            background: #d1fae5;
            color: #065f46;
            border: 1px solid #6ee7b7;
        }
        .toast-error {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        /* Responsive */
        @media (max-width: 480px) {
            .invite-name  { font-size: 3.5rem; }
            .rsvp-card    { padding: 1.8rem 1.2rem; }
            .allergens-grid { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>

<!-- ══════════════ INVITATION ══════════════ -->
<section class="invite-wrapper">
    <a href={createUrl("/")} class="btn-home">
        <i class="fa-solid fa-arrow-left"></i> Home
    </a>

    <img src="/images/leone-lion.jpeg" alt="Leone" class="lion-img" />

    <p class="invite-tagline">Con gioia vi invitiamo al</p>
    <h2 class="invite-title">Battesimo di</h2>
    <h1 class="invite-name">Leone</h1>

    <div class="date-block">
        <p class="date-month">Giugno</p>
        <div class="date-row">
            <span class="date-side">Domenica</span>
            <span class="date-day">7</span>
            <span class="date-side">Ore 11</span>
        </div>
        <p class="date-year">2026</p>
    </div>

    <div class="divider"></div>

    <div class="venue-block">
        <a class="maps-link" href="https://maps.app.goo.gl/46sgG2RNgayqA6sg9" target="_blank" rel="noopener noreferrer">
            <i class="fa-solid fa-location-dot"></i> Duomo di San Lorenzo – Piazza San Lorenzo, Viterbo
        </a>
        <div style="margin-top:0.7rem; font-size:0.78rem; color:#4a6a80; line-height:1.7;">
            <p>
                <a href="https://maps.app.goo.gl/ixo9ShuKB9d8vDKj7" target="_blank" rel="noopener noreferrer" style="color:#2c82b0; font-weight:600; text-decoration:none;">
                    <i class="fa-solid fa-square-parking"></i> Parcheggio più vicino
                </a>
                &nbsp;·&nbsp;
                <a href="https://maps.app.goo.gl/dmzcbHhek2wbqXE69" target="_blank" rel="noopener noreferrer" style="color:#2c82b0; font-weight:600; text-decoration:none;">
                    <i class="fa-solid fa-elevator"></i> Ascensore verso il Duomo
                </a>
            </p>
        </div>
        <p style="margin-top:1rem"><span class="venue-name">Casale Aderio</span></p>
        <p>Strada Teverina, Viterbo</p>
        <a class="maps-link" href="https://maps.app.goo.gl/LUo9YgAQv5HxvfiS6" target="_blank" rel="noopener noreferrer">
            <i class="fa-solid fa-location-dot"></i> Come raggiungere Casale Aderio
        </a>
    </div>

    <a href="#rsvp" class="cta-btn">
        <i class="fa-solid fa-check"></i> Conferma la tua presenza
    </a>
</section>

<!-- ══════════════ RSVP FORM ══════════════ -->
<section class="rsvp-wrapper" id="rsvp">
    <div class="rsvp-card">
        <h2 class="rsvp-title">Conferma Partecipazione</h2>
        <p class="rsvp-subtitle">Aiutaci a organizzare al meglio la giornata ✨</p>

        <form id="rsvpForm">
            <div class="form-group">
                <label for="rsvpName">Il tuo nome *</label>
                <input type="text" id="rsvpName" name="name" required maxlength="80"
                       placeholder="Nome e cognome">
            </div>

            <div class="form-group">
                <label for="rsvpPeople">Numero di persone che confermano *</label>
                <input type="number" id="rsvpPeople" name="people" required min="1" max="20"
                       placeholder="es. 2">
            </div>

            <div class="form-group">
                <label>Intolleranze alimentari</label>
                <div class="allergens-grid">
                    <label class="allergen-label">
                        <input type="checkbox" name="allergen" value="Glutine"> Glutine
                    </label>
                    <label class="allergen-label">
                        <input type="checkbox" name="allergen" value="Lattosio"> Lattosio
                    </label>
                    <label class="allergen-label">
                        <input type="checkbox" name="allergen" value="Frutta secca"> Frutta secca
                    </label>
                    <label class="allergen-label">
                        <input type="checkbox" name="allergen" value="Crostacei"> Crostacei
                    </label>
                    <label class="allergen-label">
                        <input type="checkbox" name="allergen" value="Uova"> Uova
                    </label>
                    <label class="allergen-label">
                        <input type="checkbox" name="allergen" value="Pesce"> Pesce
                    </label>
                    <label class="allergen-label">
                        <input type="checkbox" name="allergen" value="Soia"> Soia
                    </label>
                    <label class="allergen-label">
                        <input type="checkbox" name="allergen" value="Sesamo"> Sesamo
                    </label>
                </div>
            </div>

            <div class="form-group">
                <label for="rsvpOtherAllergens">Altre intolleranze</label>
                <input type="text" id="rsvpOtherAllergens" name="otherAllergens" maxlength="200"
                       placeholder="es. arachidi, sulfiti…">
            </div>

            <div class="form-group">
                <label for="rsvpNotes">Note aggiuntive</label>
                <textarea id="rsvpNotes" name="notes" maxlength="500"
                          placeholder="Qualcosa che dobbiamo sapere?"></textarea>
            </div>

            <button type="submit" class="submit-btn" id="submitBtn">
                <i class="fa-solid fa-paper-plane"></i>&nbsp; Conferma presenza
            </button>
        </form>
    </div>
</section>

<div id="toastSuccess" class="toast toast-success">
    <i class="fa-solid fa-circle-check"></i> Presenza confermata! Grazie, ci vediamo il 7 giugno! 🎉
</div>
<div id="toastError" class="toast toast-error">
    <i class="fa-solid fa-circle-xmark"></i> <span id="toastErrorMsg">Errore nell'invio, riprova.</span>
</div>

<script>
(function () {
    const GITHUB_TOKEN = 'WjJsMGFIVmlYM0JoZEY4eE1VRktWMVJhV0ZFd01HdHlkVTlSZGpOUlozRklYMVZuVDBObFdYVkVVMlo2ZEVsb1FtVkdNMjQ1ZDFab2RWSnBVbEZRVEZwVmRFMDJUR0p3ZEZneFRVRkxTVFJOVDFoQk5IcEhUa28wZGxkMg==';
    const REPO_OWNER = 'KeyserDSoze';
    const REPO_NAME  = 'leone';
    const LABEL      = 'battesimo-rsvp';
    const ISSUE_TITLE = 'RSVP Battesimo Leone \u2013 lista partecipanti';
    const API_BASE   = `https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}`;

    function decodeToken(): string {
        try {
            return atob(atob(GITHUB_TOKEN));
        } catch {
            return '';
        }
    }

    function authHeaders(): Record<string, string> {
        return {
            'Authorization': `token ${decodeToken()}`,
            'Accept': 'application/vnd.github.v3+json',
            'Content-Type': 'application/json'
        };
    }

    interface GithubIssue { number: number; title: string; body: string | null; }

    async function getOrCreateIssue(): Promise<GithubIssue> {
        const res = await fetch(
            `${API_BASE}/issues?state=open&labels=${encodeURIComponent(LABEL)}&per_page=10`,
            { headers: authHeaders() }
        );
        if (!res.ok) throw new Error(`GitHub API error: ${res.status}`);
        const issues: GithubIssue[] = await res.json();
        const existing = issues.find((i) => i.title === ISSUE_TITLE);
        if (existing) return existing;

        await ensureLabel();

        const create = await fetch(`${API_BASE}/issues`, {
            method: 'POST',
            headers: authHeaders(),
            body: JSON.stringify({ title: ISSUE_TITLE, body: '[]', labels: [LABEL] })
        });
        if (!create.ok) throw new Error(`Errore creazione issue: ${create.status}`);
        return create.json() as Promise<GithubIssue>;
    }

    async function ensureLabel(): Promise<void> {
        const check = await fetch(`${API_BASE}/labels/${encodeURIComponent(LABEL)}`, { headers: authHeaders() });
        if (check.status === 404) {
            await fetch(`${API_BASE}/labels`, {
                method: 'POST',
                headers: authHeaders(),
                body: JSON.stringify({ name: LABEL, color: '7aabcf', description: 'RSVP Battesimo Leone' })
            });
        }
    }

    interface RsvpEntry {
        nome: string;
        persone: number;
        allergeni: string[];
        altriAllergeni: string;
        note: string;
        timestamp: string;
    }

    async function submitRsvp(entry: RsvpEntry): Promise<void> {
        const issue = await getOrCreateIssue();

        let list: RsvpEntry[] = [];
        try {
            const parsed: unknown = JSON.parse(issue.body ?? '[]');
            if (Array.isArray(parsed)) list = parsed as RsvpEntry[];
        } catch { list = []; }

        list.push(entry);

        const update = await fetch(`${API_BASE}/issues/${issue.number}`, {
            method: 'PATCH',
            headers: authHeaders(),
            body: JSON.stringify({ body: JSON.stringify(list, null, 2) })
        });
        if (!update.ok) throw new Error(`Errore aggiornamento issue: ${update.status}`);
    }

    // ── Form submit ──
    const form = document.getElementById('rsvpForm') as HTMLFormElement | null;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement | null;

    form?.addEventListener('submit', async (e: Event) => {
        e.preventDefault();

        const name    = (document.getElementById('rsvpName') as HTMLInputElement).value.trim();
        const people  = parseInt((document.getElementById('rsvpPeople') as HTMLInputElement).value, 10);
        const allergens = Array.from(document.querySelectorAll<HTMLInputElement>('input[name="allergen"]:checked')).map((c) => c.value);
        const otherAllergens = (document.getElementById('rsvpOtherAllergens') as HTMLInputElement).value.trim();
        const notes   = (document.getElementById('rsvpNotes') as HTMLTextAreaElement).value.trim();

        if (!name || !people || people < 1) {
            showToast('error', 'Compila nome e numero di persone.');
            return;
        }

        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>&nbsp; Invio in corso\u2026';
        }

        try {
            await submitRsvp({ nome: name, persone: people, allergeni: allergens, altriAllergeni: otherAllergens, note: notes, timestamp: new Date().toISOString() });
            form?.reset();
            showToast('success', '');
        } catch (err) {
            console.error(err);
            showToast('error', err instanceof Error ? err.message : 'Errore sconosciuto');
        } finally {
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fa-solid fa-paper-plane"></i>&nbsp; Conferma presenza';
            }
        }
    });

    function showToast(type: 'success' | 'error', msg: string): void {
        const el = document.getElementById(type === 'success' ? 'toastSuccess' : 'toastError');
        if (!el) return;
        if (type === 'error' && msg) {
            const errMsg = document.getElementById('toastErrorMsg');
            if (errMsg) errMsg.textContent = msg;
        }
        el.style.display = 'flex';
        el.style.opacity = '1';
        setTimeout(() => {
            el.style.opacity = '0';
            setTimeout(() => { el.style.display = 'none'; }, 350);
        }, 6000);
    }
})();
</script>
</body>
</html>
