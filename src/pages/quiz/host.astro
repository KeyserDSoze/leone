---
// src/pages/quiz/host.astro — Pagina host / conduttore
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Host — CervelLeone 🦁</title>
  <link rel="icon" href="/favicon.ico" />
  <link rel="stylesheet" href="/global.css" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green-deep:  #3A5A35;
      --green:       #4B6F44;
      --green-mid:   #5C8454;
      --green-soft:  #EDF3E8;
      --green-line:  #CBDCC2;
      --gold:        #B8923D;
      --gold-soft:   #F5EEDC;
      --gold-line:   #E4D3A6;
      --ink:         #33402F;
      --muted:       #7C8A76;
      --card:        rgba(255,255,255,0.97);
      --track:       #E9EFE4;
      --danger:      #B5564B;
      --danger-soft: #F5E6E3;
    }

    body {
      font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
      color: var(--ink);
      min-height: 100vh;
      padding: 16px;
    }

    /* ── Layout ── */
    .host-layout {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 16px;
      align-items: start;
    }
    @media (max-width: 768px) {
      .host-layout { grid-template-columns: 1fr; }
    }

    /* ── Cards ── */
    .card {
      background: var(--card);
      border-radius: 20px;
      padding: 20px;
      box-shadow: 0 12px 34px rgba(58, 90, 53, 0.14);
      border: 1px solid rgba(203, 220, 194, 0.7);
      margin-bottom: 14px;
    }
    .card-title {
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--muted);
      margin-bottom: 12px;
    }

    /* ── Header ── */
    .host-header {
      background: var(--card);
      border-radius: 20px;
      padding: 16px 22px;
      box-shadow: 0 12px 34px rgba(58, 90, 53, 0.14);
      border: 1px solid rgba(203, 220, 194, 0.7);
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 10px;
    }
    .host-title {
      font-family: 'Playfull Rocket', system-ui, cursive;
      font-size: 24px;
      color: var(--green);
    }
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .status-lobby      { background: #EAF1F2; color: #3E6470; }
    .status-demo       { background: var(--green-soft); color: var(--green-deep); }
    .status-question   { background: var(--gold-soft); color: #8A6A2B; }
    .status-locked     { background: var(--danger-soft); color: #8A3E34; }
    .status-answer     { background: var(--green-soft); color: var(--green-deep); }
    .status-leaderboard{ background: #F1ECF3; color: #6A4A78; }
    .status-finished   { background: #F6F7F4; color: #5A6654; }

    /* ── QR code ── */
    #qr-img {
      width: 160px;
      height: 160px;
      border-radius: 12px;
      margin: 8px auto;
      display: block;
      border: 2px solid var(--green-line);
    }
    .player-url {
      font-size: 13px;
      color: var(--muted);
      word-break: break-all;
      text-align: center;
      margin-top: 6px;
    }
    .copy-btn {
      display: block;
      width: 100%;
      margin-top: 8px;
      padding: 8px;
      background: var(--green-soft);
      border: 1px solid var(--green-line);
      border-radius: 10px;
      font-size: 13px;
      font-weight: 600;
      color: var(--green-deep);
      cursor: pointer;
      transition: background 0.15s;
    }
    .copy-btn:hover { background: #DFEBD7; }

    /* ── Players ── */
    .player-count {
      font-size: 32px;
      font-weight: 700;
      color: var(--green);
      text-align: center;
    }
    .player-list {
      list-style: none;
      max-height: 220px;
      overflow-y: auto;
      margin-top: 8px;
    }
    .player-item {
      display: flex;
      align-items: center;
      padding: 6px 10px;
      border-radius: 8px;
      font-size: 14px;
      margin-bottom: 4px;
      background: #F7FAF4;
      border: 1px solid var(--green-line);
    }
    .player-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      margin-right: 8px;
      flex-shrink: 0;
    }
    .dot-online  { background: #5C8454; }
    .dot-offline { background: #C5CCBF; }
    .player-score { font-weight: 700; color: var(--green); font-size: 13px; }
    .answer-status { font-size: 16px; margin: 0 4px; }
    .player-item.is-offline { opacity: 0.7; }
    .player-kick {
      margin-left: 8px;
      width: 22px;
      height: 22px;
      min-width: 22px;
      border-radius: 7px;
      border: 1px solid #E3C5C0;
      background: #F5E6E3;
      color: #A24438;
      font-size: 13px;
      font-weight: 800;
      line-height: 1;
      cursor: pointer;
      transition: background 0.15s, transform 0.1s;
    }
    .player-kick:hover { background: #EFD6D1; }
    .player-kick:active { transform: scale(0.9); }
    .player-kick:disabled { opacity: 0.4; cursor: not-allowed; }

    /* ── Controls ── */
    .controls-grid {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .btn-control {
      width: 100%;
      padding: 12px 16px;
      border-radius: 12px;
      border: none;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.1s, box-shadow 0.2s, opacity 0.2s;
      text-align: left;
    }
    .btn-control:hover  { box-shadow: 0 6px 16px rgba(58,90,53,0.18); }
    .btn-control:active { transform: scale(0.98); }
    .btn-control:disabled { opacity: 0.35; cursor: not-allowed; transform: none; box-shadow: none; }

    .btn-green  { background: linear-gradient(135deg,#5C8454,#3F6539); color:#fff; }
    .btn-amber  { background: linear-gradient(135deg,#C99A4E,#A8772F); color:#fff; }
    .btn-blue   { background: linear-gradient(135deg,#5E94A6,#3E6F80); color:#fff; }
    .btn-purple { background: linear-gradient(135deg,#9079A6,#6E5683); color:#fff; }
    .btn-red    { background: linear-gradient(135deg,#C36A5F,#A04A40); color:#fff; }
    .btn-gray   { background: #E4E8E0; color: #4A5544; }

    /* ── Question panel ── */
    .question-panel {
      background: var(--card);
      border-radius: 20px;
      padding: 24px;
      box-shadow: 0 12px 34px rgba(58, 90, 53, 0.14);
      border: 1px solid rgba(203, 220, 194, 0.7);
      margin-bottom: 14px;
    }
    .q-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .q-index   { font-size: 13px; color: var(--muted); font-weight: 600; text-transform: uppercase; }
    .q-text    { font-size: 20px; font-weight: 700; color: var(--ink); line-height: 1.4; margin-bottom: 16px; }
    .q-answers { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

    .answer-card {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 12px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 600;
      border: 2px solid transparent;
      position: relative;
    }
    .answer-card .alabel {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      min-width: 28px;
      height: 28px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 800;
    }
    .answer-card .answer-copy {
      flex: 1;
      line-height: 1.45;
      padding-right: 28px;
    }
    .ac-A { background:#EAF1F2; border-color:#C3D7DD; color:#2E5A66; }
    .ac-A .alabel { background:#C3D7DD; }
    .ac-B { background:#ECF4E6; border-color:#C5DCB8; color:#3A5A35; }
    .ac-B .alabel { background:#C5DCB8; }
    .ac-C { background:#F7EFE1; border-color:#E5D2B2; color:#8A5A2B; }
    .ac-C .alabel { background:#E5D2B2; }
    .ac-D { background:#F1ECF3; border-color:#D8C8DF; color:#6A4A78; }
    .ac-D .alabel { background:#D8C8DF; }

    .answer-card.correct-reveal {
      border-color: #5C8454 !important;
      background: var(--green-soft) !important;
      color: var(--green-deep) !important;
    }
    .correct-check {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 16px;
    }

    /* Anteprima host (questionVisible=false) */
    .preview-banner {
      background: var(--gold-soft);
      border: 2px dashed var(--gold);
      border-radius: 12px;
      padding: 10px 14px;
      font-size: 13px;
      color: #8A6A2B;
      font-weight: 600;
      margin-bottom: 12px;
      text-align: center;
    }

    /* ── Host timer ── */
    .host-timer {
      font-size: 52px;
      font-weight: 700;
      color: var(--green);
      text-align: center;
      font-family: monospace;
    }
    .host-timer.urgent { color: var(--danger); animation: blink 0.5s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.4} }

    .answer-count {
      text-align: center;
      font-size: 15px;
      color: var(--muted);
      margin-top: 4px;
    }

    /* ── Next question panel ── */
    .next-q-panel {
      background: var(--green-soft);
      border: 2px solid var(--green-line);
      border-radius: 14px;
      padding: 14px 18px;
      margin-bottom: 14px;
    }
    .next-q-panel .nq-title {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--green-deep);
      margin-bottom: 6px;
    }
    .next-q-panel .nq-meta {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 4px;
    }
    .next-q-panel .nq-text {
      font-size: 14px;
      font-weight: 600;
      color: var(--green-deep);
      line-height: 1.4;
    }

    /* ── Leaderboard ── */
    .lb-host { list-style: none; }
    .lb-host li {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      border-radius: 16px;
      margin-bottom: 6px;
      background: linear-gradient(180deg, #FFFFFF, #FAFCF7);
      border: 1px solid var(--green-line);
      box-shadow: 0 10px 24px rgba(58, 90, 53, 0.06);
    }
    .lb-host li.rank1 { background:#FBF4DE; border-color:var(--gold); }
    .lb-host li.rank2 { background:#F4F6F1; border-color:#AEBBA6; }
    .lb-host li.rank3 { background:#F6EEE2; border-color:#D8B98A; }
    .lb-rank {
      width: 42px;
      min-width: 42px;
      height: 42px;
      border-radius: 14px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size:18px;
      font-weight:700;
      color:var(--green-deep);
      background: rgba(255,255,255,0.85);
    }
    .lb-copy-host { flex:1; min-width:0; }
    .lb-name-host { display:block; font-size:15px; color:var(--ink); font-weight:700; }
    .lb-meta-host { display:block; font-size:12px; color:var(--muted); margin-top:4px; }
    .lb-tags-host { display:flex; flex-wrap:wrap; gap:6px; margin-top:6px; }
    .lb-pill-host {
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:4px 8px;
      border-radius:999px;
      font-size:11px;
      font-weight:700;
      background:#EDF0EA;
      color:#5A6654;
    }
    .lb-pill-host.answer-A { background:#D9E7EC; color:#2E5A66; }
    .lb-pill-host.answer-B { background:#DDEBD3; color:#3A5A35; }
    .lb-pill-host.answer-C { background:#F0E2CA; color:#8A5A2B; }
    .lb-pill-host.answer-D { background:#E7DCEC; color:#6A4A78; }
    .lb-pill-host.correct { background:#DDEBD3; color:var(--green-deep); }
    .lb-pill-host.wrong { background:#F1DED9; color:#8A3E34; }
    .lb-pill-host.skip { background:#E4E8E0; color:#5A6654; }
    .lb-score-h {
      font-size:14px;
      font-weight:800;
      color:var(--green);
      background:#F1F6EC;
      border:1px solid var(--green-line);
      border-radius:999px;
      padding:8px 10px;
      white-space:nowrap;
    }
    .lb-reveal-step {
      font-size: 13px;
      color: var(--muted);
      margin-top: 8px;
      text-align: center;
    }

    /* ── Setup / not-admin ── */
    .setup-card {
      background: var(--card);
      border-radius: 22px;
      padding: 32px;
      max-width: 540px;
      margin: 60px auto 0;
      box-shadow: 0 18px 50px rgba(58, 90, 53, 0.16);
      border: 1px solid rgba(203, 220, 194, 0.7);
      text-align: center;
    }
    .setup-title { font-family: 'Playfull Rocket', system-ui, cursive; font-size:26px; color:var(--green); margin-bottom:12px; }
    .uid-box {
      background: #2C3A28;
      color: #DCC78A;
      font-family: monospace;
      font-size: 15px;
      padding: 14px;
      border-radius: 10px;
      word-break: break-all;
      margin: 12px 0;
      cursor: pointer;
    }
    .setup-steps { text-align:left; margin-top:16px; font-size:14px; color:var(--ink); line-height:1.8; }
    .setup-steps li { margin-left:16px; }
    .loading-setup { text-align:center; color:var(--muted); margin-top:40px; font-size:16px; }
  </style>
</head>
<body>

<!-- ── SETUP / NOT ADMIN screen ── -->
<div id="panel-setup">
  <p class="loading-setup">🦁 Connessione in corso…</p>
</div>

<!-- ── MAIN HOST panel (hidden until verified admin) ── -->
<div id="panel-host" style="display:none">

  <!-- Header -->
  <div class="host-header">
    <span class="host-title">🦁 CervelLeone</span>
    <span id="status-badge" class="status-badge status-lobby">● Lobby</span>
  </div>

  <div class="host-layout">

    <!-- ── LEFT COLUMN ── -->
    <div>

      <!-- QR Code -->
      <div class="card">
        <p class="card-title">Link giocatori</p>
        <img id="qr-img" src="" alt="QR Code" />
        <p class="player-url" id="player-url-text"></p>
        <button class="copy-btn" id="btn-copy-url">📋 Copia link</button>
      </div>

      <!-- Giocatori -->
      <div class="card">
        <p class="card-title">Giocatori in partita</p>
        <p class="player-count"><span id="player-count">0</span></p>
        <ul class="player-list" id="player-list"></ul>
      </div>

      <!-- Controlli -->
      <div class="card">
        <p class="card-title">Controlli</p>
        <div class="controls-grid" id="controls-grid">
          <!-- Rendered by JS -->
        </div>
      </div>

    </div>

    <!-- ── RIGHT COLUMN ── -->
    <div>

      <!-- Prossima domanda (visibile durante answer/leaderboard) -->
      <div class="next-q-panel" id="next-q-panel" style="display:none">
        <p class="nq-title">📋 Prossima domanda</p>
        <p class="nq-meta" id="next-q-meta"></p>
        <p class="nq-text" id="next-q-text"></p>
      </div>

      <!-- Stato / domanda corrente -->
      <div class="question-panel" id="question-panel">
        <div class="q-meta">
          <span id="q-index-label" class="q-index">In attesa</span>
          <div class="host-timer" id="host-timer" style="display:none">—</div>
        </div>
        <p id="q-text" class="q-text" style="color:#7C8A76">
          Premi "Avvia demo" o "Avvia CervelLeone" per iniziare.
        </p>
        <div class="q-answers" id="q-answers"></div>
        <p class="answer-count" id="answer-count" style="display:none"></p>
      </div>

      <!-- Anteprima classifica domanda (privata per host) -->
      <div class="card" id="question-leaderboard-panel" style="display:none">
        <p class="card-title" id="question-leaderboard-title">Anteprima classifica domanda</p>
        <ul class="lb-host" id="question-lb-list"></ul>
        <p class="lb-reveal-step" id="question-lb-reveal-step"></p>
      </div>

      <!-- Anteprima classifica generale (privata per host) -->
      <div class="card" id="leaderboard-panel" style="display:none">
        <p class="card-title" id="leaderboard-title">Classifica</p>
        <ul class="lb-host" id="lb-list"></ul>
        <p class="lb-reveal-step" id="lb-reveal-step"></p>
      </div>

    </div>
  </div>
</div>

<script>
import { db, ensureAnonymousUser } from "../../lib/firebase";
import {
  checkIsAdmin,
  resetGame,
  initGameIfNeeded,
  startQuestion,
  revealQuestion,
  closeQuestion,
  reopenQuestion,
  revealStats,
  showQuestionLeaderboard,
  showLeaderboard,
  revealNextLeaderboardStep,
  finishGame,
  kickPlayer,
} from "../../lib/quiz/hostApi";
import { setupPresence } from "../../lib/quiz/presence";
import { buildGameQuestions } from "../../lib/quiz/buildGameQuestions";
import { GAME_ID } from "../../lib/quiz/config";
import { getCorrectAnswerIds } from "../../lib/quiz/publicResult";
import { ref, onValue } from "firebase/database";
import type {
  GameState,
  LeaderboardEntry,
  Player,
  PublicQuestionLeaderboardEntry,
} from "../../lib/quiz/types";
import QRCode from "qrcode";

// ── Questions ──────────────────────────────────────────────────────────────
const questions = buildGameQuestions(); // [demo, q1..q20]
let currentUid: string | null = null;
let currentGame: GameState | null = null;
let timerInterval: ReturnType<typeof setInterval> | null = null;

// ── Shared player + answer state ───────────────────────────────────────────
let currentPlayers: Record<string, Player> = {};
let currentLeaderboard: Record<string, LeaderboardEntry> = {};
let currentAnswers: Record<string, { answerId: string }> = {};
let autoCloseTimeout: ReturnType<typeof setTimeout> | null = null;

// Sottocategorie label (per il pannello "prossima domanda")
const SUB_LABELS: Record<string, string> = {
  "geografia":           "Geografia 🌍",
  "storia-antica":       "Storia Antica 🏛️",
  "storia-moderna":      "Storia Moderna 📜",
  "tecnologia":          "Tecnologia 💻",
  "politica-italia":     "Politica 🇮🇹",
  "grammatica-italiana": "Italiano 📝",
  "matematica":          "Matematica 🔢",
  "fisica-chimica":      "Scienze 🔬",
  "arte":                "Arte & Letteratura 🎨",
  "musica":              "Musica 🎵",
  "leone":               "Leone 🦁",
  "demo":                "Demo",
};
function humanizeSub(sub?: string): string {
  return sub ? (SUB_LABELS[sub] ?? "Cultura") : "Cultura";
}

// ── QR Code generation ────────────────────────────────────────────────────
async function generateQR() {
  const base = import.meta.env.BASE_URL.replace(/\/$/, "");
  const playerUrl = `${window.location.origin}${base}/quiz`;
  const img = document.getElementById("qr-img") as HTMLImageElement | null;
  const urlText = document.getElementById("player-url-text");
  if (urlText) urlText.textContent = playerUrl;

  try {
    const dataUrl = await QRCode.toDataURL(playerUrl, {
      width: 200,
      margin: 2,
      color: { dark: "#33402F", light: "#F7FAF4" },
    });
    if (img) img.src = dataUrl;
  } catch (err) {
    console.error("QR error:", err);
  }

  const copyBtn = document.getElementById("btn-copy-url");
  copyBtn?.addEventListener("click", () => {
    navigator.clipboard.writeText(playerUrl).then(() => {
      if (copyBtn) copyBtn.textContent = "✅ Copiato!";
      setTimeout(() => { if (copyBtn) copyBtn.textContent = "📋 Copia link"; }, 2000);
    });
  });
}

// ── Status badge ───────────────────────────────────────────────────────────
const STATUS_LABELS: Record<string, string> = {
  lobby: "Lobby",
  demo: "Demo in corso",
  question: "Domanda aperta",
  locked: "Risposte chiuse",
  answer: "Risposta corretta",
  "question-leaderboard": "Velocità domanda",
  leaderboard: "Classifica",
  finished: "Fine gioco",
};
const STATUS_CLASSES: Record<string, string> = {
  lobby: "status-lobby",
  demo: "status-demo",
  question: "status-question",
  locked: "status-locked",
  answer: "status-answer",
  "question-leaderboard": "status-leaderboard",
  leaderboard: "status-leaderboard",
  finished: "status-finished",
};

function formatResponseTime(responseMs: number | null): string {
  if (responseMs == null) return "Tempo scaduto";
  const seconds = responseMs / 1000;
  return `${seconds < 10 ? seconds.toFixed(1) : Math.round(seconds)}s`;
}

function updateStatusBadge(status: string) {
  const badge = document.getElementById("status-badge");
  if (!badge) return;
  badge.textContent = `● ${STATUS_LABELS[status] ?? status}`;
  badge.className = `status-badge ${STATUS_CLASSES[status] ?? ""}`;
}

// ── Timer ──────────────────────────────────────────────────────────────────
function startHostTimer(endsAt: number) {
  stopHostTimer();
  const el = document.getElementById("host-timer");
  if (!el) return;
  el.style.display = "block";

  function tick() {
    const rem = Math.max(0, Math.ceil((endsAt - Date.now()) / 1000));
    el!.textContent = String(rem);
    el!.classList.toggle("urgent", rem <= 5);
  }
  tick();
  timerInterval = setInterval(tick, 500);
}

function stopHostTimer() {
  if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
  const el = document.getElementById("host-timer");
  if (el) el.style.display = "none";
}

// ── Answer tracking with auto-close ────────────────────────────────────────
function getActivePlayerCount(): number {
  const kicked = currentGame?.kickedUids ?? {};
  return Object.entries(currentPlayers).filter(
    ([uid, p]) => p.username && !kicked[uid]
  ).length;
}

function stopAnswerTracking() {
  if (autoCloseTimeout) { clearTimeout(autoCloseTimeout); autoCloseTimeout = null; }
  currentAnswers = {};

  const el = document.getElementById("answer-count");
  if (el) el.style.display = "none";
}

function refreshAnswerTracking() {
  if (!currentGame || !currentGame.currentQuestionId) {
    currentAnswers = {};
    renderPlayers(currentPlayers);
    return;
  }

  const questionId = currentGame.currentQuestionId;
  const gameSession = currentGame.gameSession;
  const kicked = currentGame.kickedUids ?? {};
  const trackCount =
    currentGame.status === "demo" ||
    currentGame.status === "question" ||
    currentGame.status === "locked";

  currentAnswers = Object.fromEntries(
    Object.entries(currentPlayers)
      .filter(([uid, p]) => p.username && !kicked[uid])
      .filter(
        ([, p]) =>
          p.currentAnswerGameSession === gameSession &&
          p.currentAnswerQuestionId === questionId &&
          Boolean(p.currentAnswerAnswerId)
      )
      .map(([uid, p]) => [uid, { answerId: p.currentAnswerAnswerId! }])
  );

  const answerCount = Object.keys(currentAnswers).length;
  const el = document.getElementById("answer-count");
  if (el) {
    if (trackCount) {
      el.style.display = "block";
      el.textContent = `📩 ${answerCount} risposta/e ricevuta/e`;
    } else {
      el.style.display = "none";
    }
  }

  renderPlayers(currentPlayers);

  const autoCloseActive = currentGame.status === "demo" || currentGame.status === "question";
  if (!autoCloseActive || !currentGame.questionVisible) {
    if (autoCloseTimeout) { clearTimeout(autoCloseTimeout); autoCloseTimeout = null; }
    return;
  }

  const playerCount = getActivePlayerCount();
  if (playerCount > 0 && answerCount >= playerCount && !autoCloseTimeout) {
    autoCloseTimeout = setTimeout(async () => {
      autoCloseTimeout = null;
      const qIdx = currentGame?.currentQuestionIndex;
      const sess = currentGame?.gameSession ?? "";
      if (qIdx !== undefined && qIdx >= 0 && qIdx < questions.length) {
        const closeBtn = document.getElementById("btn-close-q") as HTMLButtonElement | null;
        if (closeBtn) closeBtn.disabled = true;
        try {
          await closeQuestion(questions[qIdx], sess);
        } catch (err) {
          console.error("Auto-close error:", err);
        }
      }
    }, 1500);
  }
}

// ── Render question panel ─────────────────────────────────────────────────
function renderQuestionPanel(game: GameState) {
  const pq = game.publicCurrentQuestion;
  const pr = game.publicCurrentResult;

  const indexLabel = document.getElementById("q-index-label");
  const textEl = document.getElementById("q-text");
  const answersEl = document.getElementById("q-answers");
  const answerCountEl = document.getElementById("answer-count");

  if (!pq) {
    if (textEl) { textEl.textContent = "Premi \"Avvia demo\" o \"Avvia CervelLeone\" per iniziare."; textEl.style.color = "#7C8A76"; }
    if (indexLabel) indexLabel.textContent = "In attesa";
    if (answersEl) answersEl.innerHTML = "";
    if (answerCountEl) answerCountEl.style.display = "none";
    stopHostTimer();
    renderNextQuestionPanel(game);
    return;
  }

  const isDemo = pq.category === "demo";
  const isPreview = (game.status === "demo" || game.status === "question") && !game.questionVisible;

  if (indexLabel) {
    const subcatLabel = pq.subcategory ? ` · ${humanizeSub(pq.subcategory)}` : "";
    indexLabel.textContent = isDemo
      ? `Domanda demo (non vale punti)${isPreview ? " — ANTEPRIMA HOST" : ""}`
      : `Domanda ${pq.index} / ${pq.total}${pq.category === "leone" ? " 🦁 Leone" : subcatLabel}${isPreview ? " — ANTEPRIMA HOST" : ""}`;
  }

  if (textEl) { textEl.textContent = pq.text; textEl.style.color = "#33402F"; }

  if (answersEl) {
    const ids = ["A", "B", "C", "D"] as const;
    const correctIds = getCorrectAnswerIds(pr);
    answersEl.innerHTML = ids.map((id) => {
      const ans = pq.answers.find((a) => a.id === id);
      const isCorrect = correctIds.includes(id);
      return `<div class="answer-card ac-${id} ${isCorrect ? "correct-reveal" : ""}">
        <span class="alabel">${id})</span>
        <span class="answer-copy">${ans?.text ?? ""}</span>
        ${isCorrect ? '<span class="correct-check">✅</span>' : ""}
      </div>`;
    }).join("");
  }

  // Timer: solo quando questionVisible=true
  if ((game.status === "demo" || game.status === "question") && game.questionEndsAt && game.questionVisible) {
    startHostTimer(game.questionEndsAt);
  } else if (game.status !== "demo" && game.status !== "question") {
    stopHostTimer();
  }

  renderNextQuestionPanel(game);
}

// ── Render "prossima domanda" panel ───────────────────────────────────────
function renderNextQuestionPanel(game: GameState) {
  const panel = document.getElementById("next-q-panel");
  const metaEl = document.getElementById("next-q-meta");
  const textEl = document.getElementById("next-q-text");
  if (!panel) return;

  const showNext =
    (game.status === "answer" || game.status === "question-leaderboard" || game.status === "leaderboard") &&
    game.currentQuestionIndex >= 0;

  if (!showNext) {
    panel.style.display = "none";
    return;
  }

  const nextIdx = game.currentQuestionIndex + 1;
  if (nextIdx <= 0 || nextIdx >= questions.length) {
    panel.style.display = "none";
    return;
  }

  const nextQ = questions[nextIdx];
  panel.style.display = "block";

  if (metaEl) {
    const subLabel = nextQ.subcategory ? humanizeSub(nextQ.subcategory) : nextQ.category;
    metaEl.textContent =
      nextIdx === 0
        ? "Demo"
        : `Domanda ${nextIdx} / 20 · ${subLabel}`;
  }

  if (textEl) textEl.textContent = nextQ.text;
}

// ── Render players (filters out host, shows answer status) ─────────────────
function renderPlayers(players: Record<string, Player> | null) {
  const countEl = document.getElementById("player-count");
  const listEl = document.getElementById("player-list");

  if (!players) {
    if (countEl) countEl.textContent = "0";
    if (listEl) listEl.innerHTML = "";
    return;
  }

  // Only real players (have username); host record has no username.
  // Esclude anche i giocatori espulsi (kickedUids nello stato di gioco).
  const kicked = currentGame?.kickedUids ?? {};
  const playerEntries = Object.entries(players).filter(
    ([uid, p]) => p.username && !kicked[uid]
  );
  if (countEl) countEl.textContent = String(playerEntries.length);

  if (!listEl) return;

  const isQuestionActive =
    currentGame?.status === "demo" || currentGame?.status === "question";
  const currentQId = currentGame?.currentQuestionId;

  const sorted = [...playerEntries].sort(
    ([uidA], [uidB]) =>
      (currentLeaderboard[uidB]?.score ?? 0) - (currentLeaderboard[uidA]?.score ?? 0)
  );

  listEl.innerHTML = sorted
    .map(([uid, p]) => {
      const hasAnswered =
        isQuestionActive && currentQId ? Boolean(currentAnswers[uid]) : false;
      const statusIcon = isQuestionActive
        ? `<span class="answer-status">${hasAnswered ? "✅" : "⏳"}</span>`
        : "";
      const kickBtn = !p.connected
        ? `<button class="player-kick" data-kick="${uid}" data-name="${p.username}" title="Rimuovi giocatore offline">✕</button>`
        : "";

      return `<li class="player-item${p.connected ? "" : " is-offline"}">
        <span class="player-dot ${p.connected ? "dot-online" : "dot-offline"}"></span>
        <span style="flex:1;font-size:14px">${p.username}</span>
        ${statusIcon}
        <span class="player-score">${(currentLeaderboard[uid]?.score ?? 0).toLocaleString("it-IT")}</span>
        ${kickBtn}
      </li>`;
    })
    .join("");

  listEl.querySelectorAll<HTMLButtonElement>(".player-kick").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const uid = btn.dataset.kick;
      const name = btn.dataset.name ?? "questo giocatore";
      if (!uid) return;
      if (!confirm(`Rimuovere "${name}" dalla partita?`)) return;
      btn.disabled = true;
      try {
        await kickPlayer(uid);
      } catch (err) {
        console.error("Kick error:", err);
        btn.disabled = false;
      }
    });
  });
}

// ── Render leaderboard (host always sees all) ──────────────────────────────
function renderLeaderboard(revealStep = -1) {
  const panel = document.getElementById("leaderboard-panel");
  const listEl = document.getElementById("lb-list");
  const stepEl = document.getElementById("lb-reveal-step");
  const titleEl = document.getElementById("leaderboard-title");
  if (!panel || !listEl) return;

  const kicked = currentGame?.kickedUids ?? {};
  const raw = Object.fromEntries(
    Object.entries(currentLeaderboard).filter(([uid]) => !kicked[uid])
  ) as Record<string, LeaderboardEntry>;

  if (Object.keys(raw).length === 0) { panel.style.display = "none"; return; }

  const sorted = Object.entries(raw).sort(([, a], [, b]) => b.score - a.score);
  panel.style.display = "block";
  if (titleEl) titleEl.textContent = "Anteprima classifica generale";

  const medals = ["🥇", "🥈", "🥉"];
  listEl.innerHTML = sorted.slice(0, 10).map(([, e], i) => {
    const rank = i + 1;
    return `<li class="${rank <= 3 ? `rank${rank}` : ""}">
      <span class="lb-rank">${medals[i] ?? `${rank}.`}</span>
      <span class="lb-copy-host"><span class="lb-name-host">${e.username}</span></span>
      <span class="lb-score-h">${e.score.toLocaleString("it-IT")}</span>
    </li>`;
  }).join("");

  if (stepEl) {
    stepEl.textContent = revealStep >= 0
      ? `Rivelazione giocatori: ${Math.min(revealStep, 5)}/5`
      : "";
  }
}

function renderQuestionLeaderboard(entries: PublicQuestionLeaderboardEntry[]) {
  const panel = document.getElementById("question-leaderboard-panel");
  const listEl = document.getElementById("question-lb-list");
  const stepEl = document.getElementById("question-lb-reveal-step");
  const titleEl = document.getElementById("question-leaderboard-title");
  if (!panel || !listEl) return;

  const kicked = currentGame?.kickedUids ?? {};
  const kickedNames = new Set(
    Object.entries(currentPlayers)
      .filter(([uid]) => kicked[uid])
      .map(([, player]) => player.username)
      .filter(Boolean)
  );
  const visibleEntries = entries.filter((entry) => !kickedNames.has(entry.username));

  panel.style.display = "block";
  if (titleEl) titleEl.textContent = "Anteprima classifica domanda";
  if (stepEl) stepEl.textContent = "Ordine: risposte corrette più veloci in cima";

  if (visibleEntries.length === 0) {
    listEl.innerHTML = `<li><span class="lb-copy-host"><span class="lb-name-host">Nessun dato disponibile</span></span></li>`;
    return;
  }

  const medals = ["🥇", "🥈", "🥉"];
  listEl.innerHTML = visibleEntries.slice(0, 10).map((entry, i) => {
    const rank = i + 1;
    const answerClass = entry.answerId ? `answer-${entry.answerId}` : "skip";
    const outcomeClass = entry.isCorrect ? "correct" : entry.answerId ? "wrong" : "skip";
    const outcomeLabel = entry.isCorrect ? "Corretta" : entry.answerId ? "Sbagliata" : "Saltata";
    const pointsLabel = `${entry.points >= 0 ? "+" : ""}${entry.points.toLocaleString("it-IT")} pt`;

    return `<li class="${rank <= 3 ? `rank${rank}` : ""}">
      <span class="lb-rank">${medals[i] ?? `${rank}.`}</span>
      <div class="lb-copy-host">
        <span class="lb-name-host">${entry.username}</span>
        <span class="lb-meta-host">${formatResponseTime(entry.responseMs)}</span>
        <div class="lb-tags-host">
          <span class="lb-pill-host ${answerClass}">${entry.answerId ?? "-"}</span>
          <span class="lb-pill-host ${outcomeClass}">${outcomeLabel}</span>
        </div>
      </div>
      <span class="lb-score-h">${pointsLabel}</span>
    </li>`;
  }).join("");
}

function hideLeaderboardPanel() {
  const questionPanel = document.getElementById("question-leaderboard-panel");
  const panel = document.getElementById("leaderboard-panel");
  if (questionPanel) questionPanel.style.display = "none";
  if (panel) panel.style.display = "none";
}

// ── Controls ───────────────────────────────────────────────────────────────
function renderControls(game: GameState) {
  const grid = document.getElementById("controls-grid");
  if (!grid) return;

  const idx = game.currentQuestionIndex;
  const status = game.status;
  const qVisible = game.questionVisible === true;
  const isLastQuestion = idx === 20;
  const isAfterDemo = idx === 0 && status === "answer";
  const revealStep = game.leaderboardRevealStep ?? -1;

  const btns: { label: string; cls: string; id: string; disabled?: boolean }[] = [];

  if (status === "lobby") {
    btns.push({ label: "🎓 Avvia demo", cls: "btn-green", id: "btn-start-demo" });
    btns.push({ label: "▶️ Avvia CervelLeone (salta demo)", cls: "btn-blue", id: "btn-start-quiz" });
  }

  if ((status === "demo" || status === "question") && !qVisible) {
    // Domanda avviata ma non ancora rivelata ai player
    btns.push({ label: "▶️ Avvia timer (20s)", cls: "btn-green", id: "btn-reveal-q" });
  }

  if ((status === "demo" || status === "question") && qVisible) {
    btns.push({ label: "⏱️ Chiudi risposte", cls: "btn-amber", id: "btn-close-q" });
  }

  if (status === "locked") {
    btns.push({ label: "↩️ Riapri risposte (+20s)", cls: "btn-blue", id: "btn-reopen-q" });
    btns.push({ label: "📊 Mostra risultati", cls: "btn-amber", id: "btn-close-q" });
  }

  if (status === "answer") {
    if (isAfterDemo) {
      btns.push({ label: "▶️ Inizia CervelLeone", cls: "btn-green", id: "btn-next" });
    } else if (!game.showStats) {
      // Scores computed but bars not yet revealed
      btns.push({ label: "📊 Mostra statistiche", cls: "btn-amber", id: "btn-reveal-stats" });
    } else {
      // Stats visible → question leaderboard / overall / skip
      btns.push({ label: "⚡ Classifica domanda", cls: "btn-blue", id: "btn-show-question-lb" });
      btns.push({ label: "🏆 Mostra classifica", cls: "btn-purple", id: "btn-show-lb" });
      btns.push({
        label: isLastQuestion ? "🎉 Fine gioco" : "➡️ Prossima domanda",
        cls: isLastQuestion ? "btn-green" : "btn-amber",
        id: isLastQuestion ? "btn-finish" : "btn-next",
      });
    }
  }

  if (status === "question-leaderboard") {
    btns.push({ label: "🏆 Classifica generale", cls: "btn-purple", id: "btn-show-lb" });
    btns.push({
      label: isLastQuestion ? "🎉 Fine gioco" : "➡️ Prossima domanda",
      cls: isLastQuestion ? "btn-green" : "btn-amber",
      id: isLastQuestion ? "btn-finish" : "btn-next",
    });
  }

  if (status === "leaderboard") {
    if (revealStep < 5) {
      const rankToReveal = 5 - revealStep;
      const rankLabel =
        rankToReveal === 1
          ? "🥇 Rivela 1° posto!"
          : rankToReveal === 2
          ? "🥈 Rivela 2° posto"
          : rankToReveal === 3
          ? "🥉 Rivela 3° posto"
          : `🎭 Rivela ${rankToReveal}° posto`;
      btns.push({ label: rankLabel, cls: "btn-purple", id: "btn-reveal-step" });
    }

    btns.push({
      label: isLastQuestion ? "🎉 Fine gioco" : "➡️ Prossima domanda",
      cls: isLastQuestion ? "btn-green" : "btn-amber",
      id: isLastQuestion ? "btn-finish" : "btn-next",
    });
  }

  if (status === "finished") {
    // Only reset available
  }

  btns.push({ label: "🔄 Reset partita", cls: "btn-red", id: "btn-reset" });

  grid.innerHTML = btns
    .map(
      (b) =>
        `<button class="btn-control ${b.cls}" id="${b.id}" ${b.disabled ? "disabled" : ""}>${b.label}</button>`
    )
    .join("");

  // Bind events
  document.getElementById("btn-start-demo")?.addEventListener("click", async () => {
    await startQuestion(questions[0], 0);
  });

  document.getElementById("btn-start-quiz")?.addEventListener("click", async () => {
    await startQuestion(questions[1], 1);
  });

  document.getElementById("btn-reveal-q")?.addEventListener("click", async () => {
    const btn = document.getElementById("btn-reveal-q") as HTMLButtonElement | null;
    if (btn) btn.disabled = true;
    const qIdx = game.currentQuestionIndex;
    if (qIdx < 0 || qIdx >= questions.length) return;
    try {
      await revealQuestion(questions[qIdx], 20);
    } catch (err) {
      console.error(err);
      if (btn) btn.disabled = false;
    }
  });

  document.getElementById("btn-close-q")?.addEventListener("click", async () => {
    const btn = document.getElementById("btn-close-q") as HTMLButtonElement | null;
    if (btn) btn.disabled = true;
    // Cancel auto-close timeout if host closes manually
    if (autoCloseTimeout) { clearTimeout(autoCloseTimeout); autoCloseTimeout = null; }
    const qIdx = game.currentQuestionIndex;
    const sess = game.gameSession ?? "";
    if (qIdx < 0 || qIdx >= questions.length) return;
    try {
      await closeQuestion(questions[qIdx], sess);
    } catch (err) {
      console.error(err);
      if (btn) btn.disabled = false;
    }
  });

  document.getElementById("btn-reopen-q")?.addEventListener("click", async () => {
    const btn = document.getElementById("btn-reopen-q") as HTMLButtonElement | null;
    if (btn) btn.disabled = true;
    const qIdx = game.currentQuestionIndex;
    if (qIdx < 0 || qIdx >= questions.length) return;
    try {
      await reopenQuestion(questions[qIdx]);
    } catch (err) {
      console.error(err);
      if (btn) btn.disabled = false;
    }
  });

  document.getElementById("btn-reveal-stats")?.addEventListener("click", async () => {
    const btn = document.getElementById("btn-reveal-stats") as HTMLButtonElement | null;
    if (btn) btn.disabled = true;
    await revealStats();
  });

  document.getElementById("btn-show-question-lb")?.addEventListener("click", async () => {
    await showQuestionLeaderboard();
    renderQuestionLeaderboard(game.publicQuestionLeaderboard ?? []);
  });

  document.getElementById("btn-show-lb")?.addEventListener("click", async () => {
    await showLeaderboard();
    await renderLeaderboard(0);
  });

  document.getElementById("btn-reveal-step")?.addEventListener("click", async () => {
    const step = currentGame?.leaderboardRevealStep ?? 0;
    await revealNextLeaderboardStep(step);
    await renderLeaderboard(step + 1);
  });

  document.getElementById("btn-next")?.addEventListener("click", async () => {
    const nextIdx = game.currentQuestionIndex + 1;
    if (nextIdx < 1 || nextIdx >= questions.length) return;
    stopHostTimer();
    stopAnswerTracking();
    await startQuestion(questions[nextIdx], nextIdx);
  });

  document.getElementById("btn-finish")?.addEventListener("click", async () => {
    await finishGame();
    await renderLeaderboard(5);
  });

  document.getElementById("btn-reset")?.addEventListener("click", async () => {
    if (!confirm("Resettare la partita? I punteggi verranno azzerati.")) return;
    stopHostTimer();
    stopAnswerTracking();
    hideLeaderboardPanel();
    await resetGame();
  });
}

function shouldShowHostLeaderboardPreviews(game: GameState): boolean {
  return (
    game.currentQuestionIndex > 0 &&
    (
      game.status === "answer" ||
      game.status === "question-leaderboard" ||
      game.status === "leaderboard" ||
      game.status === "finished"
    )
  );
}

function renderHostLeaderboardPreviews(game: GameState) {
  renderQuestionLeaderboard(game.publicQuestionLeaderboard ?? []);
  renderLeaderboard(game.leaderboardRevealStep ?? -1);
}

// ── Firebase listeners ─────────────────────────────────────────────────────
function startListeners() {
  // Game state
  onValue(ref(db, `games/${GAME_ID}`), (snap) => {
    if (!snap.exists()) return;
    currentGame = snap.val() as GameState;
    updateStatusBadge(currentGame.status);
    renderQuestionPanel(currentGame);
    renderControls(currentGame);

    if (
      currentGame.status === "demo" ||
      currentGame.status === "question" ||
      currentGame.status === "locked"
    ) {
      refreshAnswerTracking();
    } else {
      stopAnswerTracking();
    }

    if (shouldShowHostLeaderboardPreviews(currentGame)) {
      renderHostLeaderboardPreviews(currentGame);
    } else {
      hideLeaderboardPanel();
    }
  });

  // Players
  onValue(ref(db, `players/${GAME_ID}`), (snap) => {
    currentPlayers = snap.val() ?? {};
    refreshAnswerTracking();
    if (currentGame && shouldShowHostLeaderboardPreviews(currentGame)) {
      renderQuestionLeaderboard(currentGame.publicQuestionLeaderboard ?? []);
    }
  });

  // Leaderboard scores for host-side player list ordering/display
  onValue(ref(db, `leaderboards/${GAME_ID}`), (snap) => {
    currentLeaderboard = snap.val() ?? {};
    renderPlayers(currentPlayers);
    if (currentGame && shouldShowHostLeaderboardPreviews(currentGame)) {
      renderLeaderboard(currentGame.leaderboardRevealStep ?? -1);
    }
  });
}

