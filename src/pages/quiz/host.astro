// ── Init ───────────────────────────────────────────────────────────────────
async function init() {
  try {
    const user = await ensureAnonymousUser();
    currentUid = user.uid;

    const isAdmin = await checkIsAdmin(currentUid);

    if (!isAdmin) {
      showNotAdmin(currentUid);
      return;
    }

    const setupEl = document.getElementById("panel-setup");
    const hostEl = document.getElementById("panel-host");
    if (setupEl) setupEl.style.display = "none";
    if (hostEl) hostEl.style.display = "block";

    await initGameIfNeeded();
    setupPresence(currentUid);
    await generateQR();
    startListeners();
  } catch (err) {
    console.error(err);
    const setup = document.getElementById("panel-setup");
    if (setup) {
      setup.innerHTML = `<div class="setup-card">
        <span style="font-size:52px">😕</span>
        <h2 class="setup-title">Errore di connessione</h2>
        <p style="color:#7C8A76;margin:8px 0">Impossibile connettersi a Firebase.</p>
        <button onclick="location.reload()" style="margin-top:12px;padding:12px 24px;background:#5C8454;color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer">
