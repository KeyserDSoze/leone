---
// src/pages/quiz/host.astro — Pagina host / conduttore
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Host — Quiz di Leone 🦁</title>
  <link rel="icon" href="/favicon.ico" />
  <link rel="stylesheet" href="/global.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      min-height: 100vh;
      padding: 16px;
    }

    /* ── Layout ── */
    .host-layout {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 16px;
      align-items: start;
    }
    @media (max-width: 768px) {
      .host-layout { grid-template-columns: 1fr; }
    }

    /* ── Cards ── */
    .card {
      background: rgba(255,255,255,0.96);
      border-radius: 18px;
      padding: 20px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.13);
      margin-bottom: 14px;
    }
    .card-title {
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #9CA3AF;
      margin-bottom: 12px;
    }

    /* ── Header ── */
    .host-header {
      background: rgba(255,255,255,0.96);
      border-radius: 18px;
      padding: 16px 22px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.13);
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 10px;
    }
    .host-title {
      font-family: 'Playfull Rocket', cursive;
      font-size: 22px;
      color: #92400E;
    }
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .status-lobby      { background: #EFF6FF; color: #1D4ED8; }
    .status-demo       { background: #F0FDF4; color: #15803D; }
    .status-question   { background: #FEF3C7; color: #92400E; }
    .status-locked     { background: #FEE2E2; color: #991B1B; }
    .status-answer     { background: #F0FDF4; color: #15803D; }
    .status-leaderboard{ background: #FDF4FF; color: #6B21A8; }
    .status-finished   { background: #F9FAFB; color: #374151; }

    /* ── QR code ── */
    #qr-img {
      width: 160px;
      height: 160px;
      border-radius: 12px;
      margin: 8px auto;
      display: block;
      border: 2px solid #FDE68A;
    }
    .player-url {
      font-size: 13px;
      color: #6B7280;
      word-break: break-all;
      text-align: center;
      margin-top: 6px;
    }
    .copy-btn {
      display: block;
      width: 100%;
      margin-top: 8px;
      padding: 8px;
      background: #FEF3C7;
      border: 1px solid #FCD34D;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 600;
      color: #92400E;
      cursor: pointer;
      transition: background 0.15s;
    }
    .copy-btn:hover { background: #FDE68A; }

    /* ── Players ── */
    .player-count {
      font-size: 32px;
      font-weight: 700;
      color: #92400E;
      text-align: center;
    }
    .player-list {
      list-style: none;
      max-height: 220px;
      overflow-y: auto;
      margin-top: 8px;
    }
    .player-item {
      display: flex;
      align-items: center;
      padding: 6px 10px;
      border-radius: 8px;
      font-size: 14px;
      margin-bottom: 4px;
      background: #FFFBEB;
      border: 1px solid #FDE68A;
    }
    .player-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      margin-right: 8px;
      flex-shrink: 0;
    }
    .dot-online  { background: #22C55E; }
    .dot-offline { background: #D1D5DB; }
    .player-score { font-weight: 700; color: #D97706; font-size: 13px; }
    .answer-status { font-size: 16px; margin: 0 4px; }

    /* ── Controls ── */
    .controls-grid {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .btn-control {
      width: 100%;
      padding: 12px 16px;
      border-radius: 12px;
      border: none;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.1s, opacity 0.2s;
      text-align: left;
    }
    .btn-control:hover  { opacity: 0.9; }
    .btn-control:active { transform: scale(0.98); }
    .btn-control:disabled { opacity: 0.35; cursor: not-allowed; transform: none; }

    .btn-green  { background: linear-gradient(135deg,#22C55E,#16A34A); color:#fff; }
    .btn-amber  { background: linear-gradient(135deg,#F59E0B,#D97706); color:#fff; }
    .btn-blue   { background: linear-gradient(135deg,#3B82F6,#2563EB); color:#fff; }
    .btn-purple { background: linear-gradient(135deg,#8B5CF6,#7C3AED); color:#fff; }
    .btn-red    { background: linear-gradient(135deg,#EF4444,#DC2626); color:#fff; }
    .btn-gray   { background: #E5E7EB; color: #374151; }

    /* ── Question panel ── */
    .question-panel {
      background: rgba(255,255,255,0.96);
      border-radius: 18px;
      padding: 24px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.13);
      margin-bottom: 14px;
    }
    .q-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .q-index   { font-size: 13px; color: #9CA3AF; font-weight: 600; text-transform: uppercase; }
    .q-text    { font-size: 20px; font-weight: 700; color: #1F2937; line-height: 1.4; margin-bottom: 16px; }
    .q-answers { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

    .answer-card {
      padding: 12px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 600;
      border: 2px solid transparent;
      position: relative;
    }
    .answer-card .alabel {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 22px;
      height: 22px;
      border-radius: 6px;
      font-size: 12px;
      margin-right: 6px;
    }
    .ac-A { background:#EFF6FF; border-color:#BFDBFE; color:#1E40AF; }
    .ac-A .alabel { background:#BFDBFE; }
    .ac-B { background:#F0FDF4; border-color:#BBF7D0; color:#166534; }
    .ac-B .alabel { background:#BBF7D0; }
    .ac-C { background:#FFF7ED; border-color:#FED7AA; color:#9A3412; }
    .ac-C .alabel { background:#FED7AA; }
    .ac-D { background:#FDF4FF; border-color:#E9D5FF; color:#6B21A8; }
    .ac-D .alabel { background:#E9D5FF; }

    .answer-card.correct-reveal {
      border-color: #22C55E !important;
      background: #F0FDF4 !important;
      color: #166534 !important;
    }
    .correct-check {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 16px;
    }

    /* Anteprima host (questionVisible=false) */
    .preview-banner {
      background: #FEF3C7;
      border: 2px dashed #F59E0B;
      border-radius: 12px;
      padding: 10px 14px;
      font-size: 13px;
      color: #92400E;
      font-weight: 600;
      margin-bottom: 12px;
      text-align: center;
    }

    /* ── Host timer ── */
    .host-timer {
      font-size: 52px;
      font-weight: 700;
      color: #92400E;
      text-align: center;
      font-family: monospace;
    }
    .host-timer.urgent { color: #DC2626; animation: blink 0.5s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.4} }

    .answer-count {
      text-align: center;
      font-size: 15px;
      color: #6B7280;
      margin-top: 4px;
    }

    /* ── Next question panel ── */
    .next-q-panel {
      background: #F0FDF4;
      border: 2px solid #86EFAC;
      border-radius: 14px;
      padding: 14px 18px;
      margin-bottom: 14px;
    }
    .next-q-panel .nq-title {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #15803D;
      margin-bottom: 6px;
    }
    .next-q-panel .nq-meta {
      font-size: 12px;
      color: #6B7280;
      margin-bottom: 4px;
    }
    .next-q-panel .nq-text {
      font-size: 14px;
      font-weight: 600;
      color: #166534;
      line-height: 1.4;
    }

    /* ── Leaderboard ── */
    .lb-host { list-style: none; }
    .lb-host li {
      display: flex;
      align-items: center;
      padding: 10px 14px;
      border-radius: 10px;
      margin-bottom: 6px;
      background: #FFFBEB;
      border: 1px solid #FDE68A;
    }
    .lb-host li.rank1 { background:#FEF9C3; border-color:#EAB308; }
    .lb-host li.rank2 { background:#F8FAFC; border-color:#94A3B8; }
    .lb-host li.rank3 { background:#FFF4ED; border-color:#FB923C; }
    .lb-rank { font-size:18px; font-weight:700; width:32px; color:#92400E; }
    .lb-name { flex:1; font-size:15px; color:#1F2937; font-weight:600; }
    .lb-score-h { font-size:15px; font-weight:700; color:#D97706; }
    .lb-reveal-step {
      font-size: 13px;
      color: #9CA3AF;
      margin-top: 8px;
      text-align: center;
    }

    /* ── Setup / not-admin ── */
    .setup-card {
      background: rgba(255,255,255,0.97);
      border-radius: 20px;
      padding: 32px;
      max-width: 540px;
      margin: 60px auto 0;
      box-shadow: 0 8px 40px rgba(0,0,0,0.15);
      text-align: center;
    }
    .setup-title { font-family: 'Playfull Rocket', cursive; font-size:26px; color:#92400E; margin-bottom:12px; }
    .uid-box {
      background: #1F2937;
      color: #FCD34D;
      font-family: monospace;
      font-size: 15px;
      padding: 14px;
      border-radius: 10px;
      word-break: break-all;
      margin: 12px 0;
      cursor: pointer;
    }
    .setup-steps { text-align:left; margin-top:16px; font-size:14px; color:#374151; line-height:1.8; }
    .setup-steps li { margin-left:16px; }
    .loading-setup { text-align:center; color:#6B7280; margin-top:40px; font-size:16px; }
  </style>
</head>
<body>

<!-- ── SETUP / NOT ADMIN screen ── -->
<div id="panel-setup">
  <p class="loading-setup">🦁 Connessione in corso…</p>
</div>

<!-- ── MAIN HOST panel (hidden until verified admin) ── -->
<div id="panel-host" style="display:none">

  <!-- Header -->
  <div class="host-header">
    <span class="host-title">🦁 Il Cervellone di Leone</span>
    <span id="status-badge" class="status-badge status-lobby">● Lobby</span>
  </div>

  <div class="host-layout">

    <!-- ── LEFT COLUMN ── -->
    <div>

      <!-- QR Code -->
      <div class="card">
        <p class="card-title">Link giocatori</p>
        <img id="qr-img" src="" alt="QR Code" />
        <p class="player-url" id="player-url-text"></p>
        <button class="copy-btn" id="btn-copy-url">📋 Copia link</button>
      </div>

      <!-- Giocatori -->
      <div class="card">
        <p class="card-title">Giocatori connessi</p>
        <p class="player-count"><span id="player-count">0</span></p>
        <ul class="player-list" id="player-list"></ul>
      </div>

      <!-- Controlli -->
      <div class="card">
        <p class="card-title">Controlli</p>
        <div class="controls-grid" id="controls-grid">
          <!-- Rendered by JS -->
        </div>
      </div>

    </div>

    <!-- ── RIGHT COLUMN ── -->
    <div>

      <!-- Prossima domanda (visibile durante answer/leaderboard) -->
      <div class="next-q-panel" id="next-q-panel" style="display:none">
        <p class="nq-title">📋 Prossima domanda</p>
        <p class="nq-meta" id="next-q-meta"></p>
        <p class="nq-text" id="next-q-text"></p>
      </div>

      <!-- Stato / domanda corrente -->
      <div class="question-panel" id="question-panel">
        <div class="q-meta">
          <span id="q-index-label" class="q-index">In attesa</span>
          <div class="host-timer" id="host-timer" style="display:none">—</div>
        </div>
        <p id="q-text" class="q-text" style="color:#9CA3AF">
          Premi "Avvia demo" o "Avvia quiz" per iniziare.
        </p>
        <div class="q-answers" id="q-answers"></div>
        <p class="answer-count" id="answer-count" style="display:none"></p>
      </div>

      <!-- Classifica -->
      <div class="card" id="leaderboard-panel" style="display:none">
        <p class="card-title">Classifica</p>
        <ul class="lb-host" id="lb-list"></ul>
        <p class="lb-reveal-step" id="lb-reveal-step"></p>
      </div>

    </div>
  </div>
</div>

<script>
import { db, ensureAnonymousUser } from "../../lib/firebase";
import {
  checkIsAdmin,
  resetGame,
  initGameIfNeeded,
  startQuestion,
  revealQuestion,
  closeQuestion,
  reopenQuestion,
  revealStats,
  showLeaderboard,
  revealNextLeaderboardStep,
  finishGame,
} from "../../lib/quiz/hostApi";
import { setupPresence } from "../../lib/quiz/presence";
import { buildGameQuestions } from "../../lib/quiz/buildGameQuestions";
import { GAME_ID } from "../../lib/quiz/config";
import { ref, onValue, get } from "firebase/database";
import type { GameState, LeaderboardEntry, Player } from "../../lib/quiz/types";
import QRCode from "qrcode";

// ── Questions ──────────────────────────────────────────────────────────────
const questions = buildGameQuestions(); // [demo, q1..q20]
let currentUid: string | null = null;
let currentGame: GameState | null = null;
let timerInterval: ReturnType<typeof setInterval> | null = null;

// ── Shared player + answer state ───────────────────────────────────────────
let currentPlayers: Record<string, Player> = {};
let currentAnswers: Record<string, { answerId: string }> = {};
let answersUnsub: (() => void) | null = null;
let autoCloseTimeout: ReturnType<typeof setTimeout> | null = null;

// Sottocategorie label (per il pannello "prossima domanda")
const SUB_LABELS: Record<string, string> = {
  "geografia":           "Geografia 🌍",
  "storia-antica":       "Storia Antica 🏛️",
  "storia-moderna":      "Storia Moderna 📜",
  "tecnologia":          "Tecnologia 💻",
  "politica-italia":     "Politica 🇮🇹",
  "grammatica-italiana": "Italiano 📝",
  "matematica":          "Matematica 🔢",
  "fisica-chimica":      "Scienze 🔬",
  "arte":                "Arte & Letteratura 🎨",
  "musica":              "Musica 🎵",
  "leone":               "Leone 🦁",
  "demo":                "Demo",
};
function humanizeSub(sub?: string): string {
  return sub ? (SUB_LABELS[sub] ?? "Cultura") : "Cultura";
}

// ── QR Code generation ────────────────────────────────────────────────────
async function generateQR() {
  const base = import.meta.env.BASE_URL.replace(/\/$/, "");
  const playerUrl = `${window.location.origin}${base}/quiz`;
  const img = document.getElementById("qr-img") as HTMLImageElement | null;
  const urlText = document.getElementById("player-url-text");
  if (urlText) urlText.textContent = playerUrl;

  try {
    const dataUrl = await QRCode.toDataURL(playerUrl, {
      width: 200,
      margin: 2,
      color: { dark: "#1F2937", light: "#FFFBEB" },
    });
    if (img) img.src = dataUrl;
  } catch (err) {
    console.error("QR error:", err);
  }

  const copyBtn = document.getElementById("btn-copy-url");
  copyBtn?.addEventListener("click", () => {
    navigator.clipboard.writeText(playerUrl).then(() => {
      if (copyBtn) copyBtn.textContent = "✅ Copiato!";
      setTimeout(() => { if (copyBtn) copyBtn.textContent = "📋 Copia link"; }, 2000);
    });
  });
}

// ── Status badge ───────────────────────────────────────────────────────────
const STATUS_LABELS: Record<string, string> = {
  lobby: "Lobby",
  demo: "Demo in corso",
  question: "Domanda aperta",
  locked: "Risposte chiuse",
  answer: "Risposta corretta",
  leaderboard: "Classifica",
  finished: "Fine gioco",
};
const STATUS_CLASSES: Record<string, string> = {
  lobby: "status-lobby",
  demo: "status-demo",
  question: "status-question",
  locked: "status-locked",
  answer: "status-answer",
  leaderboard: "status-leaderboard",
  finished: "status-finished",
};

function updateStatusBadge(status: string) {
  const badge = document.getElementById("status-badge");
  if (!badge) return;
  badge.textContent = `● ${STATUS_LABELS[status] ?? status}`;
  badge.className = `status-badge ${STATUS_CLASSES[status] ?? ""}`;
}

// ── Timer ──────────────────────────────────────────────────────────────────
function startHostTimer(endsAt: number) {
  stopHostTimer();
  const el = document.getElementById("host-timer");
  if (!el) return;
  el.style.display = "block";

  function tick() {
    const rem = Math.max(0, Math.ceil((endsAt - Date.now()) / 1000));
    el!.textContent = String(rem);
    el!.classList.toggle("urgent", rem <= 5);
  }
  tick();
  timerInterval = setInterval(tick, 500);
}

function stopHostTimer() {
  if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
  const el = document.getElementById("host-timer");
  if (el) el.style.display = "none";
}

// ── Answer tracking with auto-close ────────────────────────────────────────
function getActivePlayerCount(): number {
  return Object.values(currentPlayers).filter((p) => p.username).length;
}

function stopAnswerTracking() {
  if (answersUnsub) { answersUnsub(); answersUnsub = null; }
  if (autoCloseTimeout) { clearTimeout(autoCloseTimeout); autoCloseTimeout = null; }
  currentAnswers = {};
}

function startAnswerTracking(questionId: string, gameSession: string) {
  stopAnswerTracking();

  const ansRef = ref(db, `answers/${GAME_ID}/${gameSession}/${questionId}`);
  answersUnsub = onValue(ansRef, async (snap) => {
    currentAnswers = snap.val() ?? {};
    const answerCount = Object.keys(currentAnswers).length;

    // Update count display
    const el = document.getElementById("answer-count");
    if (el) {
      el.style.display = "block";
      el.textContent = `📩 ${answerCount} risposta/e ricevuta/e`;
    }

    // Re-render player list with updated answer status
    renderPlayers(currentPlayers);

    // Auto-close: all active players have answered
    if (!currentGame) return;
    if (currentGame.status !== "demo" && currentGame.status !== "question") return;
    // Solo se la domanda è visibile (timer avviato)
    if (!currentGame.questionVisible) return;
    if (currentGame.currentQuestionId !== questionId) return;

    const playerCount = getActivePlayerCount();
    if (playerCount > 0 && answerCount >= playerCount && !autoCloseTimeout) {
      autoCloseTimeout = setTimeout(async () => {
        autoCloseTimeout = null;
        const qIdx = currentGame?.currentQuestionIndex;
        const sess = currentGame?.gameSession ?? "";
        if (qIdx !== undefined && qIdx >= 0 && qIdx < questions.length) {
          const closeBtn = document.getElementById("btn-close-q") as HTMLButtonElement | null;
          if (closeBtn) closeBtn.disabled = true;
          try {
            await closeQuestion(questions[qIdx], sess);
          } catch (err) {
            console.error("Auto-close error:", err);
          }
        }
      }, 1500);
    }
  });
}

// ── Render question panel ─────────────────────────────────────────────────
function renderQuestionPanel(game: GameState) {
  const pq = game.publicCurrentQuestion;
  const pr = game.publicCurrentResult;

  const indexLabel = document.getElementById("q-index-label");
  const textEl = document.getElementById("q-text");
  const answersEl = document.getElementById("q-answers");
  const answerCountEl = document.getElementById("answer-count");

  if (!pq) {
    if (textEl) { textEl.textContent = "Premi \"Avvia demo\" o \"Avvia quiz\" per iniziare."; textEl.style.color = "#9CA3AF"; }
    if (indexLabel) indexLabel.textContent = "In attesa";
    if (answersEl) answersEl.innerHTML = "";
    if (answerCountEl) answerCountEl.style.display = "none";
    stopHostTimer();
    renderNextQuestionPanel(game);
    return;
  }

  const isDemo = pq.category === "demo";
  const isPreview = (game.status === "demo" || game.status === "question") && !game.questionVisible;

  if (indexLabel) {
    const subcatLabel = pq.subcategory ? ` · ${humanizeSub(pq.subcategory)}` : "";
    indexLabel.textContent = isDemo
      ? `Domanda demo (non vale punti)${isPreview ? " — ANTEPRIMA HOST" : ""}`
      : `Domanda ${pq.index} / ${pq.total}${pq.category === "leone" ? " 🦁 Leone" : subcatLabel}${isPreview ? " — ANTEPRIMA HOST" : ""}`;
  }

  if (textEl) { textEl.textContent = pq.text; textEl.style.color = "#1F2937"; }

  if (answersEl) {
    const ids = ["A", "B", "C", "D"] as const;
    const correctIds = pr?.correctAnswerIds ?? [];
    answersEl.innerHTML = ids.map((id) => {
      const ans = pq.answers.find((a) => a.id === id);
      const isCorrect = correctIds.includes(id);
      return `<div class="answer-card ac-${id} ${isCorrect ? "correct-reveal" : ""}">
        <span class="alabel">${id}</span>${ans?.text ?? ""}
        ${isCorrect ? '<span class="correct-check">✅</span>' : ""}
      </div>`;
    }).join("");
  }

  // Timer: solo quando questionVisible=true
  if ((game.status === "demo" || game.status === "question") && game.questionEndsAt && game.questionVisible) {
    startHostTimer(game.questionEndsAt);
  } else if (game.status !== "demo" && game.status !== "question") {
    stopHostTimer();
  }

  renderNextQuestionPanel(game);
}

// ── Render "prossima domanda" panel ───────────────────────────────────────
function renderNextQuestionPanel(game: GameState) {
  const panel = document.getElementById("next-q-panel");
  const metaEl = document.getElementById("next-q-meta");
  const textEl = document.getElementById("next-q-text");
  if (!panel) return;

  const showNext =
    (game.status === "answer" || game.status === "leaderboard") &&
    game.currentQuestionIndex >= 0;

  if (!showNext) {
    panel.style.display = "none";
    return;
  }

  const nextIdx = game.currentQuestionIndex + 1;
  if (nextIdx <= 0 || nextIdx >= questions.length) {
    panel.style.display = "none";
    return;
  }

  const nextQ = questions[nextIdx];
  panel.style.display = "block";

  if (metaEl) {
    const subLabel = nextQ.subcategory ? humanizeSub(nextQ.subcategory) : nextQ.category;
    metaEl.textContent =
      nextIdx === 0
        ? "Demo"
        : `Domanda ${nextIdx} / 20 · ${subLabel}`;
  }

  if (textEl) textEl.textContent = nextQ.text;
}

// ── Render players (filters out host, shows answer status) ─────────────────
function renderPlayers(players: Record<string, Player> | null) {
  const countEl = document.getElementById("player-count");
  const listEl = document.getElementById("player-list");

  if (!players) {
    if (countEl) countEl.textContent = "0";
    if (listEl) listEl.innerHTML = "";
    return;
  }

  // Only real players (have username); host record has no username
  const playerEntries = Object.entries(players).filter(([, p]) => p.username);
  const onlineCount = playerEntries.filter(([, p]) => p.connected).length;
  if (countEl) countEl.textContent = String(onlineCount);

  if (!listEl) return;

  const isQuestionActive =
    currentGame?.status === "demo" || currentGame?.status === "question";
  const currentQId = currentGame?.currentQuestionId;

  const sorted = [...playerEntries].sort(([, a], [, b]) => (b.score ?? 0) - (a.score ?? 0));

  listEl.innerHTML = sorted
    .map(([uid, p]) => {
      const hasAnswered =
        isQuestionActive && currentQId ? Boolean(currentAnswers[uid]) : false;
      const statusIcon = isQuestionActive
        ? `<span class="answer-status">${hasAnswered ? "✅" : "⏳"}</span>`
        : "";

      return `<li class="player-item">
        <span class="player-dot ${p.connected ? "dot-online" : "dot-offline"}"></span>
        <span style="flex:1;font-size:14px">${p.username}</span>
        ${statusIcon}
        <span class="player-score">${(p.score ?? 0).toLocaleString("it-IT")}</span>
      </li>`;
    })
    .join("");
}

// ── Render leaderboard (host always sees all) ──────────────────────────────
async function renderLeaderboard(revealStep = -1) {
  const panel = document.getElementById("leaderboard-panel");
  const listEl = document.getElementById("lb-list");
  const stepEl = document.getElementById("lb-reveal-step");
  if (!panel || !listEl) return;

  const snap = await get(ref(db, `leaderboards/${GAME_ID}`));
  const raw = snap.val() as Record<string, LeaderboardEntry> | null;

  if (!raw) { panel.style.display = "none"; return; }

  const sorted = Object.entries(raw).sort(([, a], [, b]) => b.score - a.score);
  panel.style.display = "block";

  const medals = ["🥇", "🥈", "🥉"];
  listEl.innerHTML = sorted.slice(0, 10).map(([, e], i) => {
    const rank = i + 1;
    return `<li class="${rank <= 3 ? `rank${rank}` : ""}">
      <span class="lb-rank">${medals[i] ?? `${rank}.`}</span>
      <span class="lb-name">${e.username}</span>
      <span class="lb-score-h">${e.score.toLocaleString("it-IT")}</span>
    </li>`;
  }).join("");

  if (stepEl) {
    stepEl.textContent = revealStep >= 0
      ? `Rivelazione giocatori: ${Math.min(revealStep, 5)}/5`
      : "";
  }
}

// ── Controls ───────────────────────────────────────────────────────────────
function renderControls(game: GameState) {
  const grid = document.getElementById("controls-grid");
  if (!grid) return;

  const idx = game.currentQuestionIndex;
  const status = game.status;
  const qVisible = game.questionVisible === true;
  const isLastQuestion = idx === 20;
  const isAfterDemo = idx === 0 && status === "answer";
  const revealStep = game.leaderboardRevealStep ?? -1;

  const btns: { label: string; cls: string; id: string; disabled?: boolean }[] = [];

  if (status === "lobby") {
    btns.push({ label: "🎓 Avvia demo", cls: "btn-green", id: "btn-start-demo" });
    btns.push({ label: "▶️ Avvia quiz (salta demo)", cls: "btn-blue", id: "btn-start-quiz" });
  }

  if ((status === "demo" || status === "question") && !qVisible) {
    // Domanda avviata ma non ancora rivelata ai player
    btns.push({ label: "▶️ Avvia timer (20s)", cls: "btn-green", id: "btn-reveal-q" });
  }

  if ((status === "demo" || status === "question") && qVisible) {
    btns.push({ label: "⏱️ Chiudi risposte", cls: "btn-amber", id: "btn-close-q" });
  }

  if (status === "locked") {
    btns.push({ label: "↩️ Riapri risposte (+20s)", cls: "btn-blue", id: "btn-reopen-q" });
    btns.push({ label: "📊 Mostra risultati", cls: "btn-amber", id: "btn-close-q" });
  }

  if (status === "answer") {
    if (isAfterDemo) {
      btns.push({ label: "▶️ Inizia il quiz", cls: "btn-green", id: "btn-next" });
    } else if (!game.showStats) {
      // Scores computed but bars not yet revealed
      btns.push({ label: "📊 Mostra statistiche", cls: "btn-amber", id: "btn-reveal-stats" });
    } else {
      // Stats visible → proceed to leaderboard
      btns.push({ label: "🏆 Mostra classifica", cls: "btn-purple", id: "btn-show-lb" });
    }
  }

  if (status === "leaderboard") {
    if (revealStep < 5) {
      const rankToReveal = 5 - revealStep;
      const rankLabel =
        rankToReveal === 1
          ? "🥇 Rivela 1° posto!"
          : rankToReveal === 2
          ? "🥈 Rivela 2° posto"
          : rankToReveal === 3
          ? "🥉 Rivela 3° posto"
          : `🎭 Rivela ${rankToReveal}° posto`;
      btns.push({ label: rankLabel, cls: "btn-purple", id: "btn-reveal-step" });
    } else {
      // All revealed
      if (isLastQuestion) {
        btns.push({ label: "🎉 Fine gioco", cls: "btn-green", id: "btn-finish" });
      } else {
        btns.push({ label: "➡️ Prossima domanda", cls: "btn-amber", id: "btn-next" });
      }
    }
  }

  if (status === "finished") {
    // Only reset available
  }

  btns.push({ label: "🔄 Reset partita", cls: "btn-red", id: "btn-reset" });

  grid.innerHTML = btns
    .map(
      (b) =>
        `<button class="btn-control ${b.cls}" id="${b.id}" ${b.disabled ? "disabled" : ""}>${b.label}</button>`
    )
    .join("");

  // Bind events
  document.getElementById("btn-start-demo")?.addEventListener("click", async () => {
    await startQuestion(questions[0], 0);
  });

  document.getElementById("btn-start-quiz")?.addEventListener("click", async () => {
    await startQuestion(questions[1], 1);
  });

  document.getElementById("btn-reveal-q")?.addEventListener("click", async () => {
    const btn = document.getElementById("btn-reveal-q") as HTMLButtonElement | null;
    if (btn) btn.disabled = true;
    const qIdx = game.currentQuestionIndex;
    if (qIdx < 0 || qIdx >= questions.length) return;
    try {
      await revealQuestion(questions[qIdx], 20);
    } catch (err) {
      console.error(err);
      if (btn) btn.disabled = false;
    }
  });

  document.getElementById("btn-close-q")?.addEventListener("click", async () => {
    const btn = document.getElementById("btn-close-q") as HTMLButtonElement | null;
    if (btn) btn.disabled = true;
    // Cancel auto-close timeout if host closes manually
    if (autoCloseTimeout) { clearTimeout(autoCloseTimeout); autoCloseTimeout = null; }
    const qIdx = game.currentQuestionIndex;
    const sess = game.gameSession ?? "";
    if (qIdx < 0 || qIdx >= questions.length) return;
    try {
      await closeQuestion(questions[qIdx], sess);
    } catch (err) {
      console.error(err);
      if (btn) btn.disabled = false;
    }
  });

  document.getElementById("btn-reopen-q")?.addEventListener("click", async () => {
    const btn = document.getElementById("btn-reopen-q") as HTMLButtonElement | null;
    if (btn) btn.disabled = true;
    const qIdx = game.currentQuestionIndex;
    if (qIdx < 0 || qIdx >= questions.length) return;
    try {
      await reopenQuestion(questions[qIdx]);
    } catch (err) {
      console.error(err);
      if (btn) btn.disabled = false;
    }
  });

  document.getElementById("btn-reveal-stats")?.addEventListener("click", async () => {
    const btn = document.getElementById("btn-reveal-stats") as HTMLButtonElement | null;
    if (btn) btn.disabled = true;
    await revealStats();
  });

  document.getElementById("btn-show-lb")?.addEventListener("click", async () => {
    await showLeaderboard();
    await renderLeaderboard(0);
  });

  document.getElementById("btn-reveal-step")?.addEventListener("click", async () => {
    const step = currentGame?.leaderboardRevealStep ?? 0;
    await revealNextLeaderboardStep(step);
    await renderLeaderboard(step + 1);
  });

  document.getElementById("btn-next")?.addEventListener("click", async () => {
    const nextIdx = game.currentQuestionIndex + 1;
    if (nextIdx < 1 || nextIdx >= questions.length) return;
    stopHostTimer();
    stopAnswerTracking();
    await startQuestion(questions[nextIdx], nextIdx);
  });

  document.getElementById("btn-finish")?.addEventListener("click", async () => {
    await finishGame();
    await renderLeaderboard(5);
  });

  document.getElementById("btn-reset")?.addEventListener("click", async () => {
    if (!confirm("Resettare la partita? I punteggi verranno azzerati.")) return;
    stopHostTimer();
    stopAnswerTracking();
    const lbPanel = document.getElementById("leaderboard-panel");
    if (lbPanel) lbPanel.style.display = "none";
    await resetGame();
  });
}

// ── Firebase listeners ─────────────────────────────────────────────────────
function startListeners() {
  let prevTrackedQuestionId: string | null = null;

  // Game state
  onValue(ref(db, `games/${GAME_ID}`), (snap) => {
    if (!snap.exists()) return;
    currentGame = snap.val() as GameState;
    updateStatusBadge(currentGame.status);
    renderQuestionPanel(currentGame);
    renderControls(currentGame);

    const isActive =
      currentGame.status === "demo" || currentGame.status === "question";
    const qId = currentGame.currentQuestionId;
    const isVisible = currentGame.questionVisible === true;

    // Start answer tracking only when question is revealed (visible)
    if (isActive && isVisible && qId && qId !== prevTrackedQuestionId) {
      prevTrackedQuestionId = qId;
      startAnswerTracking(qId, currentGame.gameSession ?? "");
    } else if (!isActive && currentGame.status !== "locked") {
      stopAnswerTracking();
    }

    if (
      currentGame.status === "leaderboard" ||
      currentGame.status === "finished"
    ) {
      renderLeaderboard(currentGame.leaderboardRevealStep ?? -1);
    }
  });

  // Players
  onValue(ref(db, `players/${GAME_ID}`), (snap) => {
    currentPlayers = snap.val() ?? {};
    renderPlayers(currentPlayers);
  });
}

// ── Not-admin screen ───────────────────────────────────────────────────────
function showNotAdmin(uid: string) {
  const setup = document.getElementById("panel-setup");
  if (setup) {
    setup.innerHTML = `
      <div class="setup-card">
        <span style="font-size:52px">🦁</span>
        <h1 class="setup-title">Configura l'Host</h1>
        <p style="font-size:14px;color:#6B7280;margin-bottom:8px">
          Il tuo browser non è ancora autorizzato come host.<br>
          Copia il tuo UID e aggiungilo in Firebase Console.
        </p>
        <div class="uid-box" id="uid-display" title="Clicca per copiare">${uid}</div>
        <button onclick="navigator.clipboard.writeText('${uid}').then(()=>document.getElementById('uid-display').textContent='✅ Copiato!')"
          style="background:#FEF3C7;border:1px solid #FCD34D;border-radius:10px;padding:8px 16px;cursor:pointer;font-weight:600;color:#92400E;font-size:14px">
          📋 Copia UID
        </button>
        <ol class="setup-steps">
          <li>Vai su <strong>Firebase Console → Realtime Database</strong></li>
          <li>Naviga in <code>admins/</code></li>
          <li>Aggiungi la chiave <code>${uid}</code> con valore <code>true</code></li>
          <li>Ricarica questa pagina</li>
        </ol>
        <button onclick="location.reload()"
          style="margin-top:16px;width:100%;padding:12px;background:linear-gradient(135deg,#F59E0B,#D97706);color:#fff;border:none;border-radius:12px;font-size:16px;font-weight:700;cursor:pointer">
          🔄 Ricarica dopo la configurazione
        </button>
      </div>`;
  }
}

// ── Init ───────────────────────────────────────────────────────────────────
async function init() {
  try {
    const user = await ensureAnonymousUser();
    currentUid = user.uid;

    const isAdmin = await checkIsAdmin(currentUid);

    if (!isAdmin) {
      showNotAdmin(currentUid);
      return;
    }

    const setupEl = document.getElementById("panel-setup");
    const hostEl = document.getElementById("panel-host");
    if (setupEl) setupEl.style.display = "none";
    if (hostEl) hostEl.style.display = "block";

    await initGameIfNeeded();
    setupPresence(currentUid);
    await generateQR();
    startListeners();
  } catch (err) {
    console.error(err);
    const setup = document.getElementById("panel-setup");
    if (setup) {
      setup.innerHTML = `<div class="setup-card">
        <span style="font-size:52px">😕</span>
        <h2 class="setup-title">Errore di connessione</h2>
        <p style="color:#6B7280;margin:8px 0">Impossibile connettersi a Firebase.</p>
        <button onclick="location.reload()" style="margin-top:12px;padding:12px 24px;background:#F59E0B;color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer">
          Riprova 🔄
        </button>
      </div>`;
    }
  }
}

init();
</script>

